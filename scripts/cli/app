#!/usr/bin/env bash
# shellcheck source-path=SCRIPTDIR
# foundry — CLI front-end for the change-lifecycle backend.
#
# Two modes:
#   interactive   — default in a TTY; uses gum for icons/colors/prompts
#   --plain       — deterministic output for Claude Code or pipelines
#                   (also auto-enabled when stdout isn't a TTY)
#
# This file is bootstrap ONLY: locate the plugin, parse global flags,
# source every component, dispatch the subcommand.  All logic lives in
# the components listed in the manifest below:
#
#   config/    — constants (buckets) + user config lookup
#   spec/      — CRISPY rules (mirrors skills/spec/): state machine,
#                slug naming, artifact lint gates
#   store/     — change data: CRUD (change.sh, subprocess), tracking,
#                index cache, read queries, file templating
#   render/    — everything that draws: ANSI primitives, row/column/
#                markdown/history formatting, branded header, picker widget
#   commands/  — plain subcommands: list show new move sync setup help
#   pages/     — interactive picker pages: main_page, list_page, detail_page
#
# All state mutations go through store/change.sh.
#
# Exit codes (one convention across every component):
#   0   success
#   1   domain refusal — not found, transition rejected by state machine
#   2   environment problem — no .foundry/, missing template, bad plugin path
#   64  usage error — unknown subcommand/flag, missing argument

set -euo pipefail
export LC_ALL="${LC_ALL:-en_US.UTF-8}"

# ── locate ourselves (resolve symlink chain so .foundry/cli pointing
# back at the plugin works the same as a direct call). app lives at
# scripts/cli/, so the plugin root is two levels up from resolve_self().─────────────────
resolve_self() {
  local self_path="${BASH_SOURCE[0]}"
  while [[ -L "$self_path" ]]; do
    local link_target; link_target="$(readlink "$self_path")"
    if [[ "$link_target" = /* ]]; then self_path="$link_target"
    else self_path="$(dirname "$self_path")/$link_target"
    fi
  done
  cd "$(dirname "$self_path")" && pwd
}
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(resolve_self)/../.." && pwd)}"
CLI_DIR="$PLUGIN_ROOT/scripts/cli"

# Subprocess scripts (executed, not sourced — same entry points that
# /foundry:change and /foundry:setup use from Claude Code).
CHANGE_SH="$CLI_DIR/store/change.sh"
TRACKING_SH="$CLI_DIR/store/tracking.sh"
STATE_MACHINE_SH="$CLI_DIR/spec/state-machine.sh"

# ── parse --plain anywhere in the args ────────────────────────────────────
ARGS=()
for arg in "$@"; do
  if [[ "$arg" == "--plain" ]]; then
    export FOUNDRY_PLAIN=1
  else
    ARGS+=("$arg")
  fi
done
# ${ARGS[@]+…} guard: bash 3.2 + set -u treat an empty array as unbound.
set -- "${ARGS[@]+"${ARGS[@]}"}"

# ── project store ─────────────────────────────────────────────────────────
FOUNDRY_ROOT="${FOUNDRY_ROOT:-$PWD/.foundry}"
CHANGES_DIR="$FOUNDRY_ROOT/changes"

# ── component manifest (source order = dependency order) ──────────────────
# shellcheck source=config/constants.sh
. "$CLI_DIR/config/constants.sh"
# shellcheck source=config/config_loader.sh
. "$CLI_DIR/config/config_loader.sh"
# shellcheck source=render/primitives.sh
. "$CLI_DIR/render/primitives.sh"
# shellcheck source=store/index_cache.sh
. "$CLI_DIR/store/index_cache.sh"
# shellcheck source=store/query.sh
. "$CLI_DIR/store/query.sh"
# shellcheck source=spec/slug.sh
. "$CLI_DIR/spec/slug.sh"
# shellcheck source=render/table.sh
. "$CLI_DIR/render/table.sh"
# shellcheck source=render/brand_header.sh
. "$CLI_DIR/render/brand_header.sh"
# shellcheck source=render/markdown.sh
. "$CLI_DIR/render/markdown.sh"
# shellcheck source=render/history.sh
. "$CLI_DIR/render/history.sh"
# shellcheck source=render/picker_widget.sh
. "$CLI_DIR/render/picker_widget.sh"
# shellcheck source=commands/help.sh
. "$CLI_DIR/commands/help.sh"
# shellcheck source=commands/list_changes.sh
. "$CLI_DIR/commands/list_changes.sh"
# shellcheck source=commands/show_change.sh
. "$CLI_DIR/commands/show_change.sh"
# shellcheck source=commands/new_change.sh
. "$CLI_DIR/commands/new_change.sh"
# shellcheck source=commands/move_change.sh
. "$CLI_DIR/commands/move_change.sh"
# shellcheck source=commands/sync_indexes.sh
. "$CLI_DIR/commands/sync_indexes.sh"
# shellcheck source=commands/setup_project.sh
. "$CLI_DIR/commands/setup_project.sh"
# shellcheck source=pages/main_page.sh
. "$CLI_DIR/pages/main_page.sh"
# shellcheck source=pages/list_page.sh
. "$CLI_DIR/pages/list_page.sh"
# shellcheck source=pages/detail_page.sh
. "$CLI_DIR/pages/detail_page.sh"

# ── dispatch guard ────────────────────────────────────────────────────────
require_foundry() {
  [[ -d "$CHANGES_DIR" ]] || { ui_error "no .foundry/ — run: foundry setup"; exit 2; }
}

# ── dispatch ──────────────────────────────────────────────────────────────
main() {
  if [[ $# -eq 0 ]]; then
    main_page
    return
  fi
  local subcommand="$1"; shift
  case "$subcommand" in
    list)            cmd_list_changes "$@" ;;
    show)            cmd_show_change "$@" ;;
    new)             cmd_new_change "$@" ;;
    move)            cmd_move_change "$@" ;;
    setup)           cmd_setup_project "$@" ;;
    sync)            cmd_sync_indexes "$@" ;;
    -h|--help|help)  cmd_help ;;
    *)               ui_error "unknown subcommand: $subcommand"; cmd_help; exit 64 ;;
  esac
}

main "$@"
