{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/trajectory-counter.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay \"${CLAUDE_PLUGIN_ROOT}/assets/sounds/stop.m4r\" >/dev/null 2>&1 &"
          }
        ]
      }
    ]
  }
}
