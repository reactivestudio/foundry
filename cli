#!/usr/bin/env bash
# foundry — CLI front-end for the change-lifecycle backend.
#
# Two modes:
#   interactive   — default in a TTY; uses gum for icons/colors/prompts
#   --plain       — deterministic output for Claude Code or pipelines
#                   (also auto-enabled when stdout isn't a TTY)
#
# All state mutations go through scripts/change.sh.

set -euo pipefail
export LC_ALL="${LC_ALL:-en_US.UTF-8}"

# ── locate ourselves (resolve symlink chain so .foundry/cli pointing
# back at the plugin works the same as a direct call). cli lives at
# the plugin root, so resolve_self() IS the plugin root. ──────────────────
resolve_self() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local tgt; tgt="$(readlink "$src")"
    if [[ "$tgt" = /* ]]; then src="$tgt"
    else src="$(dirname "$src")/$tgt"
    fi
  done
  cd "$(dirname "$src")" && pwd
}
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(resolve_self)}"
SCRIPTS="$PLUGIN_ROOT/scripts"
CHANGE_SH="$SCRIPTS/change.sh"
SETUP_SH="$SCRIPTS/setup.sh"
TRACKING_SH="$SCRIPTS/tracking.sh"

# ── parse --plain anywhere in the args ────────────────────────────────────
ARGS=()
for arg in "$@"; do
  if [[ "$arg" == "--plain" ]]; then
    export FOUNDRY_PLAIN=1
  else
    ARGS+=("$arg")
  fi
done
set -- "${ARGS[@]+"${ARGS[@]}"}"

# shellcheck source=../scripts/lib/ui.sh
. "$SCRIPTS/lib/ui.sh"
# shellcheck source=../scripts/lib/constants.sh
. "$SCRIPTS/lib/constants.sh"
# shellcheck source=../scripts/lib/config.sh
. "$SCRIPTS/lib/config.sh"

# ── helpers ───────────────────────────────────────────────────────────────
FOUNDRY_ROOT="${FOUNDRY_ROOT:-$PWD/.foundry}"
CHANGES_DIR="$FOUNDRY_ROOT/changes"

usage() {
  cat <<'EOF'
usage:
  foundry                          interactive: pick a change and act
  foundry list [--bucket=X]        list changes (all or filtered)
  foundry show <slug>              show a change's tracking + history
  foundry new ["title"]            create a change (asks for title if omitted)
  foundry move <slug> [--to=X] [--reason=R]
                                   move a change between buckets
  foundry setup                    scaffold .foundry/ in the current project

global flags:
  --plain                          ASCII output, no prompts
EOF
  exit 64
}

require_foundry() {
  [[ -d "$CHANGES_DIR" ]] || { ui_error "no .foundry/ — run: foundry setup"; exit 2; }
}

# Echo bucket containing slug or empty + exit 1.
find_bucket() {
  local slug="$1"
  for b in "${BUCKETS[@]}"; do
    [[ -d "$CHANGES_DIR/$b/$slug" ]] && { echo "$b"; return 0; }
  done
  return 1
}

# Compute "age" string from a tracking.yaml updated_at field.
age_of() {
  local dir="$1"
  local ts; ts=$("$TRACKING_SH" get "$dir" updated_at 2>/dev/null) || return 0
  [[ -z "$ts" ]] && return 0
  local now; now=$(date -u +%s)
  local then
  if then=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$ts" +%s 2>/dev/null); then
    :
  elif then=$(date -u -d "$ts" +%s 2>/dev/null); then
    :
  else
    echo "?"; return 0
  fi
  local delta=$((now - then))
  if   (( delta < 60 ));      then echo "${delta}s"
  elif (( delta < 3600 ));    then echo "$((delta / 60))m"
  elif (( delta < 86400 ));   then echo "$((delta / 3600))h"
  elif (( delta < 604800 ));  then echo "$((delta / 86400))d"
  else                              echo "$((delta / 604800))w"
  fi
}

# Emit a TSV row per change:
#   bucket  slug  title  age_str  updated_epoch  created_epoch
collect_rows() {
  local filter="${1:-all}"
  local buckets=("${BUCKETS[@]}")
  [[ "$filter" != "all" ]] && buckets=("$filter")
  shopt -s nullglob
  for b in "${buckets[@]}"; do
    [[ -d "$CHANGES_DIR/$b" ]] || continue
    for entry in "$CHANGES_DIR/$b"/*/; do
      local slug; slug=$(basename "$entry")
      local title; title=$("$TRACKING_SH" get "$entry" title 2>/dev/null || echo "?")
      local age;   age=$(age_of "$entry")
      local ut;    ut=$("$TRACKING_SH" get "$entry" updated_at 2>/dev/null || echo "")
      local ct;    ct=$("$TRACKING_SH" get "$entry" created_at 2>/dev/null || echo "")
      local upd_epoch=0 crt_epoch=0
      [[ -n "$ut" ]] && upd_epoch=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$ut" +%s 2>/dev/null \
                                  || date -u -d "$ut" +%s 2>/dev/null || echo 0)
      [[ -n "$ct" ]] && crt_epoch=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$ct" +%s 2>/dev/null \
                                  || date -u -d "$ct" +%s 2>/dev/null || echo 0)
      printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$b" "$slug" "$title" "$age" "$upd_epoch" "$crt_epoch"
    done
  done
  shopt -u nullglob
}

# ── subcommands ───────────────────────────────────────────────────────────

# Render a single row of the list (icon + slug + title + age, all
# padded/colored). Used by both the grouped renderer and --bucket flat.
render_row() {
  local b="$1" slug="$2" title="$3" epoch="$4"
  local slug_w="$5" title_w="$6" upd_w="$7"

  local rel="?"
  if [[ "$epoch" != "0" ]]; then
    local iso
    iso=$(date -u -r "$epoch" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null \
       || date -u -d "@$epoch" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || echo "")
    [[ -n "$iso" ]] && rel=$(ui_date_relative "$iso")
  fi
  local s_t; s_t=$(ui_truncate "$slug_w" "$slug")
  local t_t; t_t=$(ui_truncate "$title_w" "$title")
  printf '  %s  %s  %s  %s\n' \
    "$(ui_status_icon "$b")" \
    "$(ui_bright "$(printf '%-*s' "$slug_w" "$s_t")")" \
    "$(ui_paint fd_title "$(printf '%-*s' "$title_w" "$t_t")")" \
    "$(ui_paint fd_updated "$(printf '%-*s' "$upd_w" "$rel")")"
}

# Apply --sort within a set of rows.
apply_sort() {
  local sort="$1" reverse="$2"
  local order_flag="-r"; [[ "$reverse" == "1" ]] && order_flag=""
  case "$sort" in
    updated) sort -t$'\t' -k5 -n $order_flag ;;
    created) sort -t$'\t' -k6 -n $order_flag ;;
    slug)    sort -t$'\t' -k2 $order_flag ;;
    title)   sort -t$'\t' -k3 -f $order_flag ;;
    *)       cat ;;
  esac
}

# Resolve column widths from terminal size.
col_widths() {
  local cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 100)}
  (( cols > 120 )) && cols=120
  local slug_w=28 upd_w=12
  local title_w=$(( cols - 4 - slug_w - 2 - upd_w - 4 ))
  (( title_w < 20 )) && title_w=20
  printf '%d %d %d' "$slug_w" "$title_w" "$upd_w"
}

# Render one bucket section: divider with name + count, capped rows,
# "⋯ +N more" footer when truncated. Skips empty buckets.
render_bucket_section() {
  local b="$1" all_rows="$2" sort="$3" reverse="$4" limit="$5"
  local bucket_rows; bucket_rows=$(printf '%s\n' "$all_rows" | awk -F'\t' -v b="$b" '$1 == b')
  [[ -z "$bucket_rows" ]] && return

  local n; n=$(printf '%s\n' "$bucket_rows" | wc -l | tr -d ' ')

  printf '\n'
  ui_divider "$(ui_status "$b") · $n"

  bucket_rows=$(printf '%s\n' "$bucket_rows" | apply_sort "$sort" "$reverse")

  local show="$bucket_rows"
  if (( n > limit )); then
    show=$(printf '%s\n' "$bucket_rows" | head -n "$limit")
  fi

  read -r slug_w title_w upd_w <<< "$(col_widths)"
  while IFS=$'\t' read -r bb slug title _ upd _crt; do
    render_row "$bb" "$slug" "$title" "$upd" "$slug_w" "$title_w" "$upd_w"
  done <<< "$show"

  if (( n > limit )); then
    local more=$((n - limit))
    printf '  %s  %s\n' \
      "$(ui_dim '⋯')" \
      "$(ui_dim "+$more more in $b — foundry list --bucket=$b")"
  fi
}

cmd_list() {
  require_foundry
  local filter="all" sort
  sort="$(config_get default_sort updated)"
  local reverse=0
  [[ "$(config_get default_reverse false)" == "true" ]] && reverse=1

  for arg in "$@"; do
    case "$arg" in
      --bucket=*) filter="${arg#--bucket=}" ;;
      --sort=*)   sort="${arg#--sort=}" ;;
      --reverse)  reverse=1 ;;
      *) ui_error "unknown flag: $arg"; exit 64 ;;
    esac
  done

  case "$sort" in
    updated|created|slug|title) ;;
    *) ui_error "--sort must be one of: updated, created, slug, title"; exit 64 ;;
  esac

  local rows; rows=$(collect_rows all)

  if [[ -z "$rows" ]]; then
    ui_header "Foundry" "empty"
    ui_info "get started: foundry new \"your idea\""
    echo
    return 0
  fi

  local total; total=$(printf '%s\n' "$rows" | wc -l | tr -d ' ')
  local arrow; (( reverse )) && arrow='↑' || arrow='↓'

  if [[ "$filter" != "all" ]]; then
    # single-bucket view — no grouping, no cap.
    local bucket_rows; bucket_rows=$(printf '%s\n' "$rows" | awk -F'\t' -v b="$filter" '$1 == b')
    local n=0
    [[ -n "$bucket_rows" ]] && n=$(printf '%s\n' "$bucket_rows" | wc -l | tr -d ' ')
    if (( n == 0 )); then
      ui_header "Foundry" "$(ui_status "$filter") · empty"
      echo
      return 0
    fi
    ui_header "Foundry" "$(ui_status "$filter") · $n · sort: $sort $arrow"
    read -r slug_w title_w upd_w <<< "$(col_widths)"
    while IFS=$'\t' read -r bb slug title _ upd _crt; do
      render_row "$bb" "$slug" "$title" "$upd" "$slug_w" "$title_w" "$upd_w"
    done < <(printf '%s\n' "$bucket_rows" | apply_sort "$sort" "$reverse")
    echo
    return 0
  fi

  # Grouped view: summary line + section per non-empty bucket.
  local breakdown=""
  for b in "${BUCKETS[@]}"; do
    local cnt; cnt=$(printf '%s\n' "$rows" | awk -F'\t' -v b="$b" '$1 == b' | wc -l | tr -d ' ')
    breakdown+="$(ui_status_icon "$b") $cnt  "
  done
  ui_header "Foundry" "$total · ${breakdown% } · sort: $sort $arrow"
  local limit; limit="$(config_get list_per_bucket_limit 3)"
  for b in "${BUCKETS[@]}"; do
    render_bucket_section "$b" "$rows" "$sort" "$reverse" "$limit"
  done
  echo

  if [[ "$UI_MODE" == "interactive" ]]; then
    printf '  %s  %s\n' \
      "$(ui_dim 'open      :')" "$(ui_dim 'foundry show <slug>')"
    printf '  %s  %s\n' \
      "$(ui_dim 'add       :')" "$(ui_dim 'foundry new "your idea"')"
    printf '  %s  %s\n' \
      "$(ui_dim 'one bucket:')" "$(ui_dim 'foundry list --bucket=<status>')"
    printf '  %s  %s\n' \
      "$(ui_dim 'configure :')" "$(ui_dim '.foundry/config.yaml')"
    echo
  fi
}

cmd_show() {
  require_foundry
  local slug="${1:-}"
  [[ -n "$slug" ]] || { ui_error "show: missing slug"; exit 64; }
  local b
  if ! b=$(find_bucket "$slug" 2>/dev/null); then
    ui_error "not found: $slug"
    # offer near matches
    local hits
    hits=$(collect_rows all 2>/dev/null | awk -F'\t' -v q="$slug" '
      BEGIN { lq = tolower(q) }
      index(tolower($2), lq) > 0 || index(tolower($3), lq) > 0 { print $0 }
    ' | head -5)
    if [[ -n "$hits" ]]; then
      echo
      ui_info "did you mean:"
      while IFS=$'\t' read -r bb ss tt _ _; do
        printf '    %s  %s  %s\n' \
          "$(ui_status_icon "$bb")" \
          "$(ui_bright "$ss")" \
          "$(ui_dim "$tt")"
      done <<< "$hits"
      echo
    fi
    exit 1
  fi
  local dir="$CHANGES_DIR/$b/$slug"

  local title;   title=$("$TRACKING_SH" get "$dir" title 2>/dev/null)
  local status;  status=$("$TRACKING_SH" get "$dir" status 2>/dev/null)
  local created; created=$("$TRACKING_SH" get "$dir" created_at 2>/dev/null)
  local updated; updated=$("$TRACKING_SH" get "$dir" updated_at 2>/dev/null)
  local reason;  reason=$("$TRACKING_SH" get "$dir" decline_reason 2>/dev/null || true)

  # ── header: icon + slug, then title as h1, then metadata ──
  echo
  printf '  %s  %s\n' "$(ui_status_icon "$b")" "$(ui_paint fd_title "$slug")"
  printf '  %s\n' "$(ui_paint fd_title "$title")"
  echo
  printf '  %s  %s\n' \
    "$(printf '%-10s' "$(ui_dim "status")")" \
    "$(ui_paint "$(ui_bucket_color "$b")" "$status")"
  printf '  %s  %s\n' \
    "$(printf '%-10s' "$(ui_dim "updated")")" \
    "$(ui_paint fd_updated "$(ui_date_relative "$updated") · $(ui_date_full "$updated")")"
  printf '  %s  %s\n' \
    "$(printf '%-10s' "$(ui_dim "created")")" \
    "$(ui_paint fd_created "$(ui_date_full "$created")")"
  [[ -n "$reason" ]] && printf '  %s  %s\n' \
    "$(printf '%-10s' "$(ui_dim "reason")")" \
    "$(ui_paint "$(ui_bucket_color "$b")" "$reason")"
  echo

  # ── proposal preview: first N content lines, dim, blanks collapsed ──
  if [[ -f "$dir/proposal.md" ]]; then
    ui_divider "proposal"
    local n=12
    local shown=0 total_content
    total_content=$(grep -cE '[^[:space:]]' "$dir/proposal.md" || echo 0)
    grep -E '[^[:space:]]' "$dir/proposal.md" | head -n "$n" | while IFS= read -r line; do
      printf '  %s\n' "$(ui_dim "$line")"
    done
    if (( total_content > n )); then
      printf '  %s\n' "$(ui_dim "  … $((total_content - n)) more lines in proposal.md")"
    fi
    echo
  fi

  # ── history: log-style, newest first ──
  if [[ -f "$dir/history.log" ]]; then
    ui_divider "history"
    {
      tac "$dir/history.log" 2>/dev/null || tail -r "$dir/history.log"
    } | head -10 | while IFS=$'\t' read -r ts actor event details; do
      local rel; rel=$(ui_date_relative "$ts")
      local actor_color=muted
      [[ "$actor" == "user" ]] && actor_color=ok
      [[ "$actor" == "state-machine" ]] && actor_color=accent
      # Pretty details: "backlog->declined (reason)" → "backlog → declined"
      # with reason rendered as a second indented line.
      local pretty="$details" reason_line=""
      pretty="${pretty//->/ → }"
      if [[ "$pretty" =~ ^(.+)\ \((.+)\)$ ]]; then
        pretty="${BASH_REMATCH[1]}"
        reason_line="${BASH_REMATCH[2]}"
      fi
      printf '  %s  %s  %s  %s\n' \
        "$(ui_dim "$(printf '%-12s' "$rel")")" \
        "$(ui_paint "$actor_color" "$(printf '%-14s' "$actor")")" \
        "$(ui_bright "$(printf '%-8s' "$event")")" \
        "$pretty"
      if [[ -n "$reason_line" ]]; then
        printf '  %s  %s  %s  %s\n' \
          "            " "              " "        " \
          "$(ui_dim "\"$reason_line\"")"
      fi
    done
    echo
  fi

  # ── next actions ──
  if [[ "$UI_MODE" == "interactive" ]]; then
    ui_divider "next"
    case "$b" in
      backlog)
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=in-progress")" "$(ui_dim '— start')"
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=declined --reason=\"…\"")" "$(ui_dim '— decline')"
        ;;
      in-progress)
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=done")" "$(ui_dim '— finish')"
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=backlog")" "$(ui_dim '— pause')"
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=declined --reason=\"…\"")" "$(ui_dim '— decline')"
        ;;
      done)
        printf '  %s\n' "$(ui_dim '(terminal — no transitions out)')"
        ;;
      declined)
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=backlog")" "$(ui_dim '— revive')"
        ;;
    esac
    echo
  fi
}

cmd_new() {
  local title="${1:-}"
  if [[ -z "$title" ]]; then
    if [[ "$UI_MODE" == "interactive" ]]; then
      title=$(ui_input "Change title (free text)")
      [[ -z "$title" ]] && { ui_error "title required"; exit 1; }
    else
      ui_error "new: title required as argument in --plain mode"
      exit 64
    fi
  fi

  # Slug generation: ASCII-fold the title, kebab-case it. Caller can
  # override by passing FOUNDRY_SLUG=... env (used by Claude Code when
  # it wants to LLM-pick a semantic slug).
  local slug="${FOUNDRY_SLUG:-}"
  if [[ -z "$slug" ]]; then
    slug=$(printf '%s' "$title" \
      | iconv -f utf-8 -t ascii//translit 2>/dev/null \
      | tr '[:upper:]' '[:lower:]' \
      | tr -c 'a-z0-9' '-' \
      | sed -E 's/-+/-/g; s/^-+|-+$//g' \
      | cut -c1-40)
    [[ -z "$slug" ]] && slug="change-$(date +%s)"
  fi

  require_foundry
  "$CHANGE_SH" new "$slug" "$title" >/dev/null
  ui_header "$(ui_status_icon backlog) $slug" "created in backlog"
  ui_info "edit: .foundry/changes/backlog/$slug/proposal.md"
  echo
}

cmd_move() {
  require_foundry
  local slug="${1:-}"
  [[ -n "$slug" ]] || { ui_error "move: missing slug"; exit 64; }
  shift

  local to="" reason=""
  for arg in "$@"; do
    case "$arg" in
      --to=*)     to="${arg#--to=}" ;;
      --reason=*) reason="${arg#--reason=}" ;;
      *) ui_error "unknown flag: $arg"; exit 64 ;;
    esac
  done

  local from; from=$(find_bucket "$slug") || { ui_error "not found: $slug"; exit 1; }

  if [[ -z "$to" ]]; then
    if [[ "$UI_MODE" == "interactive" ]]; then
      # offer all buckets except current
      local opts=()
      for b in "${BUCKETS[@]}"; do
        [[ "$b" == "$from" ]] && continue
        opts+=("$(ui_icon "$b") $b")
      done
      local pick; pick=$(ui_choose "Move $slug from $(ui_icon "$from") $from to:" "${opts[@]}") || exit 1
      to="${pick#* }"
    else
      ui_error "move: --to=<bucket> required in --plain mode"
      exit 64
    fi
  fi

  if [[ "$to" == "declined" && -z "$reason" ]]; then
    if [[ "$UI_MODE" == "interactive" ]]; then
      reason=$(ui_input "Reason for declining")
      [[ -z "$reason" ]] && { ui_error "decline reason required"; exit 1; }
    else
      ui_error "move to declined: --reason=... required in --plain mode"
      exit 64
    fi
  fi

  local out
  if out=$("$CHANGE_SH" move "$slug" "$to" ${reason:+"$reason"} 2>&1); then
    printf '\n  %s  %s  %s %s %s\n\n' \
      "$(ui_paint ok '✓')" \
      "$(ui_bright "$slug")" \
      "$(ui_status_icon "$from")" \
      "$(ui_dim '→')" \
      "$(ui_status "$to")"
  else
    printf '%s\n' "$out" >&2
    exit 1
  fi
}

cmd_setup() {
  bash "$SETUP_SH" "$@"
}

# Press-any-key gate; used between an action's output and the next redraw.
pause_for_user() {
  printf '\n  %s ' "$(ui_dim 'press ↵ to continue')"
  read -r _ || true
}

# (Action buttons live in a separate bar — see horizontal_action_bar.
# Earlier sentinels SENT_ADD/SORT/RELOAD/EXIT were removed in 0.26.0.)

# Format one change row for the picker (slug NOT displayed — looked up
# via parallel arrays PICKER_ENTRIES + PICKER_SLUGS in cmd_interactive).
# Columns: icon, bucket-text, title, created, updated
# build_row_parts — populate per-row globals consumed by build_full_row and
# by ui_picker (for filter-match title highlighting). Side-effects:
#   ROW_LEFT       — painted "<icon>  <padded bucket>  "
#   ROW_TITLE      — raw, ANSI-free, truncated title text (unpadded)
#   ROW_TITLE_W    — visual width to pad title to (column alignment)
#   ROW_RIGHT      — painted "  <padded created>  <padded updated>"
# build_full_row composes ROW_LEFT + painted(padded(ROW_TITLE)) + ROW_RIGHT.
# ui_picker, when a filter is active and the title matches, re-paints the
# title slot with highlight ANSI around the match while keeping LEFT/RIGHT
# unchanged.
build_row_parts() {
  local b="$1" title="$2" upd_epoch="$3" crt_epoch="$4"

  local cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 100)}
  (( cols > 140 )) && cols=140
  local bucket_w=12 created_w=18 updated_w=11
  local title_w=$(( cols - bucket_w - created_w - updated_w - 10 ))
  (( title_w < 20 )) && title_w=20

  local created_str updated_str
  if [[ "$crt_epoch" != "0" ]]; then
    local iso; iso=$(date -u -r "$crt_epoch" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null \
                || date -u -d "@$crt_epoch" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null)
    created_str=$(ui_date_full "$iso")
  else
    created_str="?"
  fi
  if [[ "$upd_epoch" != "0" ]]; then
    local iso; iso=$(date -u -r "$upd_epoch" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null \
                || date -u -d "@$upd_epoch" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null)
    updated_str=$(ui_date_relative "$iso")
  else
    updated_str="?"
  fi

  ROW_TITLE=$(ui_truncate "$title_w" "$title")
  ROW_TITLE_W=$title_w
  ROW_LEFT=$(printf '%s  %s  ' \
    "$(ui_status_icon "$b")" \
    "$(ui_paint "$(ui_bucket_color "$b")" "$(printf '%-*s' "$bucket_w" "$b")")")
  ROW_RIGHT=$(printf '  %s  %s' \
    "$(ui_paint fd_created "$(printf '%-*s' "$created_w" "$created_str")")" \
    "$(ui_paint fd_updated "$(printf '%-*s' "$updated_w" "$updated_str")")")
}

build_full_row() {
  build_row_parts "$@"
  local padded; padded=$(printf '%-*s' "$ROW_TITLE_W" "$ROW_TITLE")
  printf '%s%s%s' "$ROW_LEFT" "$(ui_paint fd_title "$padded")" "$ROW_RIGHT"
}

# Strip ANSI + trailing whitespace — used to normalize picker rows for
# matching. ui_picker now returns the slug directly, but ui_drill / other
# helpers still use this to clean copy of an entry.
_norm_picker_line() {
  printf '%s' "$1" | sed -E $'s/\033\\[[0-9;]*[a-zA-Z]//g' | sed -E 's/[[:space:]]+$//'
}

# Drill into one change: show + action menu.
ui_drill() {
  local slug="$1"
  clear
  cmd_show "$slug"
  local b; b=$(find_bucket "$slug") || { pause_for_user; return; }
  # Action-verb icons, colored to match the target state's brand color.
  local ic_start="$(ui_paint fd_inprogress '▶')"   # play → start work
  local ic_finish="$(ui_paint fd_done '✓')"        # check → finish
  local ic_pause="$(ui_paint fd_backlog '⏸')"     # pause bars → pause
  local ic_revive="$(ui_paint fd_backlog '↩')"    # return arrow → revive (back from declined)
  local ic_decl="$(ui_paint fd_declined '×')"     # multiplication sign → decline
  local ic_back="$(ui_paint fd_chrome '←')"        # left arrow → back

  local actions=()
  case "$b" in
    backlog)
      actions=(
        "$ic_start Start (move to in-progress)"
        "$ic_decl Decline"
        "$ic_back Back"
      ) ;;
    in-progress)
      actions=(
        "$ic_finish Finish (move to done)"
        "$ic_pause Pause back to backlog"
        "$ic_decl Decline"
        "$ic_back Back"
      ) ;;
    done)
      actions=("$ic_back Back (terminal — no transitions out)") ;;
    declined)
      actions=(
        "$ic_revive Revive (back to backlog)"
        "$ic_back Back"
      ) ;;
  esac
  local action
  action=$(gum choose --header "What next?" \
    --header.foreground 153 \
    --item.foreground 117 \
    --cursor.foreground 255 \
    --selected.foreground 255 \
    "${actions[@]}") || return
  case "$action" in
    *"Start"*)
      cmd_move "$slug" --to=in-progress
      pause_for_user ;;
    *"Finish"*)
      cmd_move "$slug" --to=done
      pause_for_user ;;
    *"Pause"*)
      cmd_move "$slug" --to=backlog
      pause_for_user ;;
    *"Revive"*)
      cmd_move "$slug" --to=backlog
      pause_for_user ;;
    *"Decline"*)
      local reason
      reason=$(gum input --placeholder "Reason for declining" --header "Decline $slug")
      if [[ -n "$reason" ]]; then
        cmd_move "$slug" --to=declined --reason="$reason"
        pause_for_user
      fi ;;
    *) ;;
  esac
}

# Prompt for a title → create → return (caller redraws).
ui_add_new() {
  clear
  ui_header "Foundry" "new change"
  local title
  title=$(gum input --placeholder "Change title (free text)" --width 60)
  [[ -z "$title" ]] && return
  cmd_new "$title"
  pause_for_user
}

# (Sort picker removed in 0.26.0 per user feedback. Sort is set once
# from .foundry/config.yaml's default_sort.)

# (horizontal_action_bar + render_static_list removed in 0.31.0 — action
# items now live as picker entries handled by ui_picker, no separate mode.)

# Single-bucket paged view (entered from "+N more" row). Reuses ui_picker
# with bucket-specific column header, page summary, and pagination actions.
ui_bucket_view() {
  local bucket="$1"
  local page=1 per_page; per_page="$(config_get bucket_page_size 20)"

  while true; do
    local rows; rows=$(collect_rows all | awk -F'\t' -v b="$bucket" '$1 == b' \
                      | apply_sort "$MAIN_SORT" "$MAIN_REVERSE")
    local total=0
    [[ -n "$rows" ]] && total=$(printf '%s\n' "$rows" | wc -l | tr -d ' ')
    (( total == 0 )) && return
    local pages=$(( (total + per_page - 1) / per_page ))
    (( pages < 1 )) && pages=1
    local start=$(( (page - 1) * per_page + 1 ))
    local end=$(( page * per_page ))
    (( end > total )) && end=$total
    local page_rows; page_rows=$(printf '%s\n' "$rows" | sed -n "${start},${end}p")

    PICKER_ENTRIES=()
    PICKER_SLUGS=()
    PICKER_TYPES=()
    PICKER_FILTERABLE=()
    PICKER_BUCKET=()
    PICKER_TITLE=()
    PICKER_TITLE_W=()
    PICKER_LEFT=()
    PICKER_RIGHT=()

    # Column header.
    PICKER_ENTRIES+=("$(_build_header_row)")
    PICKER_SLUGS+=("")
    PICKER_TYPES+=("header")
    PICKER_FILTERABLE+=("0")
    _picker_meta_empty

    # Bucket rows.  Same parts plumbing as build_main_entries so that
    # filter-match title highlighting works here too.
    while IFS=$'\t' read -r bb slug title _ upd crt; do
      build_row_parts "$bb" "$title" "$upd" "$crt"
      local _padded; _padded=$(printf '%-*s' "$ROW_TITLE_W" "$ROW_TITLE")
      PICKER_ENTRIES+=("${ROW_LEFT}$(ui_paint fd_title "$_padded")${ROW_RIGHT}")
      PICKER_SLUGS+=("$slug")
      PICKER_TYPES+=("row")
      PICKER_FILTERABLE+=("1")
      PICKER_BUCKET+=("$bb")
      PICKER_TITLE+=("$ROW_TITLE")
      PICKER_TITLE_W+=("$ROW_TITLE_W")
      PICKER_LEFT+=("$ROW_LEFT")
      PICKER_RIGHT+=("$ROW_RIGHT")
    done <<< "$page_rows"

    # Padding → summary → padding.
    PICKER_ENTRIES+=("")
    PICKER_SLUGS+=("")
    PICKER_TYPES+=("padding")
    PICKER_FILTERABLE+=("0")
    _picker_meta_empty

    PICKER_ENTRIES+=("   $(ui_paint fd_chrome "$(ui_status "$bucket")  ·  page $page of $pages  ·  $total total")")
    PICKER_SLUGS+=("")
    PICKER_TYPES+=("summary")
    PICKER_FILTERABLE+=("0")
    _picker_meta_empty

    PICKER_ENTRIES+=("")
    PICKER_SLUGS+=("")
    PICKER_TYPES+=("padding")
    PICKER_FILTERABLE+=("0")
    _picker_meta_empty

    # Pagination + back actions.
    if (( page > 1 )); then
      PICKER_ENTRIES+=("$(ui_paint fd_chrome "◀  Previous page")")
      PICKER_SLUGS+=("__bv_prev__")
      PICKER_TYPES+=("action")
      PICKER_FILTERABLE+=("0")
      _picker_meta_empty
    fi
    if (( page < pages )); then
      PICKER_ENTRIES+=("$(ui_paint fd_chrome "▶  Next page")")
      PICKER_SLUGS+=("__bv_next__")
      PICKER_TYPES+=("action")
      PICKER_FILTERABLE+=("0")
      _picker_meta_empty
    fi
    PICKER_ENTRIES+=("$(ui_paint fd_chrome "←  Back to all changes")")
    PICKER_SLUGS+=("__bv_back__")
    PICKER_TYPES+=("action")
    PICKER_FILTERABLE+=("0")
    _picker_meta_empty

    # Branded header with the active bucket as trailing context — the user
    # sees "foundry · change ledger · ⊙ in-progress (12)" so the screen
    # tells them exactly what they're filtered into.
    local _bucket_painted
    _bucket_painted="$(ui_paint fd_icon "$(ui_icon "$bucket")") $(ui_paint "$(ui_bucket_color "$bucket")" "$bucket")"
    PICKER_HEADER="$(build_picker_header "${_bucket_painted} $(ui_dim "($total)")")"
    if ui_picker "⌕ Search "; then
      case "$PICKER_RESULT_SLUG" in
        __bv_prev__) page=$((page - 1)) ;;
        __bv_next__) page=$((page + 1)) ;;
        __bv_back__) return ;;
        '') ;;
        *) ui_drill "$PICKER_RESULT_SLUG" ;;
      esac
    else
      return
    fi
  done
}

# Sentinel labels (plain — used in case patterns AFTER _norm_picker_line
# strips ANSI). Display values are produced via ui_paint fd_chrome when
# building picker entries.
ACT_ADD='+  Add new change'
ACT_RELOAD='⟳  Reload'
ACT_EXIT='⏻  Exit'

# Build the brand header line shown above the search prompt.  Layout:
#
#     ⬢ foundry  ·  change ledger  ·  ⟨context⟩
#
# Pieces:
#   ⬢            — brand mark in neon purple (fd_search) — accent dot
#   foundry      — app name in bright primary (ui_bright)
#   ·            — separator in dim
#   change ledger— static subtitle in dim
#   ⟨context⟩    — optional caller-supplied trailing context (e.g. the
#                  current bucket name in its bucket color, or a count)
#
# Returns a single ANSI-painted line — caller assigns it to PICKER_HEADER.
build_picker_header() {
  local trailing="${1:-}"
  local out
  out="$(ui_paint fd_search '⬢')  "
  out+="$(ui_bright 'foundry')  "
  out+="$(ui_dim '·')  "
  out+="$(ui_dim 'change ledger')"
  if [[ -n "$trailing" ]]; then
    out+="  $(ui_dim '·')  ${trailing}"
  fi
  printf '%s' "$out"
}

# Helper: column widths used by both build_full_row and the picker
# header / "+N more" rows so everything aligns.
_picker_widths() {
  local cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 100)}
  (( cols > 140 )) && cols=140
  local bucket_w=12 created_w=18 updated_w=11
  local title_w=$(( cols - bucket_w - created_w - updated_w - 10 ))
  (( title_w < 20 )) && title_w=20
  printf '%d %d %d %d' "$bucket_w" "$title_w" "$created_w" "$updated_w"
}

# Build the column-header line for the custom picker. The picker prefixes
# each rendered row with "▸ " (cursor) or "  " (non-cursor) — 2 cells.
# Row content is then icon(1) + sep(2) + bucket, so bucket text starts at
# column 5. The column-header line has no icon, so 3 leading spaces here +
# 2 cells from the picker = 5 → STATUS aligns with "backlog".
# Small-caps via ui_pad_visual which counts visual cells (wc -m).
_build_header_row() {
  read -r bw tw cw uw <<< "$(_picker_widths)"
  printf '   %s  %s  %s  %s' \
    "$(ui_dim "$(ui_pad_visual "$(ui_small_caps STATUS)" "$bw")")" \
    "$(ui_dim "$(ui_pad_visual "$(ui_small_caps TITLE)" "$tw")")" \
    "$(ui_dim "$(ui_pad_visual "$(ui_small_caps CREATED)" "$cw")")" \
    "$(ui_dim "$(ui_pad_visual "$(ui_small_caps UPDATED)" "$uw")")"
}

# Build a "+N more items..." row formatted like a regular change row,
# but with the icon AND bucket columns blank. Text uses ui_dim so it
# reads as secondary/meta versus the brighter title color of real rows.
_build_more_row() {
  local b="$1" n="$2"
  read -r bw tw cw uw <<< "$(_picker_widths)"
  printf '   %s  %s  %s  %s' \
    "$(printf '%-*s' "$bw" "")" \
    "$(ui_dim "$(printf '%-*s' "$tw" "+$n more items...")")" \
    "$(printf '%-*s' "$cw" "")" \
    "$(printf '%-*s' "$uw" "")"
}

# Build summary pseudo-row. 3 leading spaces match column-header indent
# (skip icon column) so the summary aligns with the bucket column.
# Colors:
#   "N changes"       → ui_dim (matches column header chrome)
#   "·" separator     → ui_dim
#   "<icon> <count>"  → per-bucket color (one painted segment so ANSI
#                       reset doesn't bleed back to dim)
_build_summary_row() {
  local total="$1" all_rows="$2"
  local s
  s="$(ui_dim "$total changes")"
  local b
  for b in "${BUCKETS[@]}"; do
    local cnt; cnt=$(printf '%s\n' "$all_rows" | awk -F'\t' -v b="$b" '$1 == b' | wc -l | tr -d ' ')
    s+="  $(ui_dim '·')  $(ui_paint "$(ui_bucket_color "$b")" "$(ui_icon "$b") $cnt")"
  done
  printf '   %s' "$s"
}

# ── ui_picker — custom interactive picker ─────────────────────────────────
#
# Why custom: gum filter and fzf both visit every row with the cursor — no
# way to skip non-selectables (column headers, summary, padding) in the
# middle of the list. This picker reads parallel arrays the caller fills:
#
#   PICKER_ENTRIES[i]    — display line (may contain ANSI escapes)
#   PICKER_SLUGS[i]      — return key for selectables; "" otherwise
#   PICKER_TYPES[i]      — 'row' | 'action' | 'header' | 'padding' | 'summary'
#   PICKER_FILTERABLE[i] — '1' to include row in text-filter; '0' to always show
#
# Optional per-row (set only for type='row'; default to '' for the rest):
#   PICKER_BUCKET[i]   — bucket name; powers Tab → jump to next bucket
#   PICKER_TITLE[i]    — raw title text (truncated, unpadded, no ANSI)
#   PICKER_TITLE_W[i]  — target visual width for padding the title cell
#   PICKER_LEFT[i]     — pre-painted "<icon>  <bucket>  " segment
#   PICKER_RIGHT[i]    — pre-painted "  <created>  <updated>" segment
# When a filter is active and the row's title contains the filter substring
# (case-insensitive), the picker rebuilds the row from LEFT + highlighted
# title + RIGHT so the match appears in fd_match (pale gold) while the rest
# of the title stays in fd_title.
#
# Cursor only lands on type='row' or 'action'. Type-to-filter is always on:
# typed chars build a substring filter against filterable entries (rows).
# Non-filterable entries (headers/summary/padding/actions) always show.
#
# Keys:
#   ↑ / ↓     move cursor through selectables
#   Tab       on 'row'    → jump to first selectable of the NEXT bucket
#             on 'action' → behave like ↓
#   ↵         select (sets PICKER_RESULT_SLUG and returns 0)
#   ⌫         delete one char from filter
#   ⎋         cancel (returns 1)
#
# Sets globals on selection:
#   PICKER_RESULT_SLUG, PICKER_RESULT_ENTRY
# Return: 0 = ↵ selected, 1 = esc.
ui_picker() {
  local prompt_label="${1:-⌕ Search }"

  local filter="" filter_lc="" cursor=0
  local stty_save; stty_save=$(stty -g)
  stty -echo -icanon
  # Hide the hardware cursor — we draw our own ▌ block so we control its
  # color (neon purple) and run a soft fade ourselves.  Terminals can't
  # repaint their native caret, so faking it is the only way.
  printf '\033[?25l'

  PICKER_RESULT_SLUG=""
  PICKER_RESULT_ENTRY=""
  local rc=0
  local n_total=${#PICKER_ENTRIES[@]}

  # ── per-picker caches built ONCE ─────────────────────────────────────────
  # Pre-derive everything that doesn't depend on the filter or cursor so
  # the per-frame loop stays in pure bash — no sed/tr forks during render.
  #   entries_lc[i]     — ANSI-stripped lowercase for substring filtering
  #   entries_bright[i] — entry recoloured as primary (used when cursor
  #                       lands on an action item)
  #   title_lc[i]       — lowercase raw title for filter-match highlighting
  local -a entries_lc=() entries_bright=() title_lc=()
  local i stripped
  for (( i = 0; i < n_total; i++ )); do
    stripped=""
    if [[ "${PICKER_FILTERABLE[$i]}" == "1" || "${PICKER_TYPES[$i]}" == "action" ]]; then
      stripped=$(printf '%s' "${PICKER_ENTRIES[$i]}" | ui_strip_ansi)
    fi
    if [[ "${PICKER_FILTERABLE[$i]}" == "1" ]]; then
      entries_lc[$i]=$(printf '%s' "$stripped" | tr '[:upper:]' '[:lower:]')
    else
      entries_lc[$i]=""
    fi
    if [[ "${PICKER_TYPES[$i]}" == "action" ]]; then
      entries_bright[$i]=$(ui_bright "$stripped")
    else
      entries_bright[$i]=""
    fi
    if [[ "${PICKER_TYPES[$i]}" == "row" && -n "${PICKER_TITLE[$i]:-}" ]]; then
      title_lc[$i]=$(printf '%s' "${PICKER_TITLE[$i]}" | tr '[:upper:]' '[:lower:]')
    else
      title_lc[$i]=""
    fi
  done

  # Static render fragments.
  local prompt_painted; prompt_painted=$(ui_paint fd_search "$prompt_label")
  local cursor_arrow;   cursor_arrow=$(ui_bright '▸')

  # Optional one-line header above the search prompt.  Callers set
  # PICKER_HEADER (a fully-painted, ANSI-styled single line) to brand the
  # screen.  When set, the prompt row shifts from row 2 to row 4 (header
  # on row 2, blank row 3, prompt row 4) — the caret animator pulses on
  # whichever row the prompt ends up on.
  local picker_header="${PICKER_HEADER:-}"
  local caret_row=2
  [[ -n "$picker_header" ]] && caret_row=4

  # ── caret pulse sidecar ──────────────────────────────────────────────────
  # A background process drives the caret animation while the main loop
  # blocks on read().  The animator cycles through a 6-phase smooth fade
  # at row 2, painting a single ▌ glyph per tick.  This decouples cursor
  # animation from input — read() can block forever on the main loop and
  # the caret keeps breathing.
  #
  # Coordination: before drawing a full frame the main loop SIGSTOPs the
  # animator so its writes can't interleave with the frame's bytes, then
  # SIGCONTs after the frame and the new cursor column have been written.
  # Cleanup on exit: rm the col file (animator loop sees missing file and
  # exits), then SIGTERM, then wait.
  local anim_col_file; anim_col_file=$(mktemp -t fdcaret 2>/dev/null || mktemp)
  printf '%d' 14 > "$anim_col_file"

  (
    # The subshell inherits set -euo pipefail from the parent; disable so
    # transient failures (kill races on parent shutdown, tmp-file read
    # blips) can't tear down the animator prematurely.
    set +eu
    trap 'exit 0' TERM INT
    phase=0
    while [[ -f "$anim_col_file" ]]; do
      col=$(<"$anim_col_file" 2>/dev/null) || break
      [[ -z "$col" ]] && col=14
      # Ten-phase symmetric breath on the purple ramp:
      #   135 → 141 → 147 → 183 → 189 → 189 → 183 → 147 → 141 → 135
      # Same hue, gently desaturating to pale lilac then climbing back.
      # The trough is held for one extra tick (phases 4 & 5 both = 189)
      # so the dim moment lingers — reads as a real "in / out" breath.
      # At 250 ms / tick the full cycle is ~2.5 s, comfortable to look at.
      # $caret_row is captured from the parent scope at subshell fork time.
      case "$phase" in
        0) printf '\033[%s;%sH\033[38;5;135m▌\033[0m' "$caret_row" "$col" ;;
        1) printf '\033[%s;%sH\033[38;5;141m▌\033[0m' "$caret_row" "$col" ;;
        2) printf '\033[%s;%sH\033[38;5;147m▌\033[0m' "$caret_row" "$col" ;;
        3) printf '\033[%s;%sH\033[38;5;183m▌\033[0m' "$caret_row" "$col" ;;
        4) printf '\033[%s;%sH\033[38;5;189m▌\033[0m' "$caret_row" "$col" ;;
        5) printf '\033[%s;%sH\033[38;5;189m▌\033[0m' "$caret_row" "$col" ;;
        6) printf '\033[%s;%sH\033[38;5;183m▌\033[0m' "$caret_row" "$col" ;;
        7) printf '\033[%s;%sH\033[38;5;147m▌\033[0m' "$caret_row" "$col" ;;
        8) printf '\033[%s;%sH\033[38;5;141m▌\033[0m' "$caret_row" "$col" ;;
        9) printf '\033[%s;%sH\033[38;5;135m▌\033[0m' "$caret_row" "$col" ;;
      esac
      phase=$(( (phase + 1) % 10 ))
      sleep 0.25
    done
  ) </dev/null >/dev/tty 2>/dev/null &
  local anim_pid=$!

  # PROMPT_COLS = 4 leading spaces + len("⌕ Search ") = 4 + 9 = 13.
  # Caret column at row 2 = PROMPT_COLS + 1 + ${#filter}.
  local PROMPT_COLS=13

  local needs_full_redraw=1
  local n_sel=0 current=-1
  local -a vis_idx=() sel_idx=()

  while true; do
    if (( needs_full_redraw )); then
      # Freeze the animator so its mid-tick write can't tear the frame.
      # `|| true` because under set -e a missing pid would abort the loop;
      # if the animator already died, we just keep going without a pulse.
      kill -STOP "$anim_pid" 2>/dev/null || true

      # ── filter pass ─────────────────────────────────────────────────────
      vis_idx=(); sel_idx=()
      for (( i = 0; i < n_total; i++ )); do
        if [[ "${PICKER_FILTERABLE[$i]}" == "1" && -n "$filter_lc" ]]; then
          [[ "${entries_lc[$i]}" != *"$filter_lc"* ]] && continue
        fi
        vis_idx+=("$i")
        if [[ "${PICKER_TYPES[$i]}" == "row" || "${PICKER_TYPES[$i]}" == "action" ]]; then
          sel_idx+=("$((${#vis_idx[@]} - 1))")
        fi
      done

      n_sel=${#sel_idx[@]}
      if (( n_sel == 0 )); then
        cursor=0
      else
        (( cursor >= n_sel )) && cursor=$((n_sel - 1))
        (( cursor < 0 )) && cursor=0
      fi
      current=-1
      (( n_sel > 0 )) && current="${sel_idx[$cursor]}"

      # ── render one frame in one printf ──────────────────────────────────
      # \033[H\033[2J replaces the external `clear`.  4 leading spaces
      # aligns prompt 'S' with column-header 'S'.  A bright caret glyph
      # is painted here once; the animator will overwrite the same cell
      # on its next tick to continue the pulse.  When PICKER_HEADER is set
      # the header sits on row 2 with a blank row 3 buffer, pushing the
      # prompt down to row 4 (matches caret_row above).
      local frame=$'\033[H\033[2J\n'
      if [[ -n "$picker_header" ]]; then
        frame+=$'    '"${picker_header}"$'\n\n'
      fi
      frame+=$'    '"${prompt_painted}$(ui_bright "$filter")"$'\033[38;5;135m▌\033[0m\n\n'
      local j idx row_render is_cursor
      for (( j = 0; j < ${#vis_idx[@]}; j++ )); do
        idx="${vis_idx[$j]}"
        is_cursor=0
        (( j == current )) && is_cursor=1
        # Title color:
        #   153 = fd_title  (baby blue) when not on cursor
        #   255 = primary   (bright)    when cursor is on this row
        # action items get full ANSI-stripped bright via entries_bright (no
        # column-specific recolouring) — same code path as before.
        # Row types: when the cursor lands on the row, or when the user is
        # typing a filter that matches the row's title, we rebuild the
        # title cell from raw parts (PICKER_TITLE / PICKER_LEFT / PICKER_RIGHT)
        # so we can paint title-color + optional fd_match (222) highlight.
        if [[ "${PICKER_TYPES[$idx]}" == "row" ]]; then
          local _tc=153 _has_match=0
          (( is_cursor )) && _tc=255
          if [[ -n "$filter_lc" && -n "${title_lc[$idx]}" \
                && "${title_lc[$idx]}" == *"$filter_lc"* ]]; then
            _has_match=1
          fi
          if (( _has_match || is_cursor )); then
            local _t _tw
            _t="${PICKER_TITLE[$idx]}"
            _tw="${PICKER_TITLE_W[$idx]}"
            # NB: split assignments — bash 3.2 evaluates `local a=… b=$((…a…))`
            # right-to-left through the outer scope, which trips set -u when
            # `a` doesn't exist there yet.
            local _vlen _pad _padding
            _vlen=${#_t}
            _pad=$((_tw - _vlen))
            (( _pad < 0 )) && _pad=0
            printf -v _padding '%*s' "$_pad" ''
            if (( _has_match )); then
              local _lc _before_lc _pos _mlen _pre _mat _suf _hl
              _lc="${title_lc[$idx]}"
              _before_lc="${_lc%%"$filter_lc"*}"
              _pos=${#_before_lc}
              _mlen=${#filter_lc}
              _pre="${_t:0:_pos}"
              _mat="${_t:_pos:_mlen}"
              _suf="${_t:_pos+_mlen}"
              # title-color prefix → fd_match (222) match → title-color suffix
              # → trailing pad, reset.  title-color picks 153 or 255.
              printf -v _hl '\033[38;5;%sm%s\033[38;5;222m%s\033[38;5;%sm%s%s\033[0m' \
                "$_tc" "$_pre" "$_mat" "$_tc" "$_suf" "$_padding"
              row_render="${PICKER_LEFT[$idx]}${_hl}${PICKER_RIGHT[$idx]}"
            else
              # Cursor on row, no filter match — recolour title to bright.
              local _ti
              printf -v _ti '\033[38;5;%sm%s%s\033[0m' "$_tc" "$_t" "$_padding"
              row_render="${PICKER_LEFT[$idx]}${_ti}${PICKER_RIGHT[$idx]}"
            fi
          else
            row_render="${PICKER_ENTRIES[$idx]}"
          fi
        else
          row_render="${PICKER_ENTRIES[$idx]}"
        fi
        if (( is_cursor )); then
          if [[ "${PICKER_TYPES[$idx]}" == "action" ]]; then
            frame+=" ${cursor_arrow} ${entries_bright[$idx]}"$'\n'
          else
            frame+=" ${cursor_arrow} ${row_render}"$'\n'
          fi
        else
          frame+="   ${row_render}"$'\n'
        fi
      done
      printf '%s' "$frame"

      # Tell the animator the new caret column, then resume the pulse.
      local cur_col=$((PROMPT_COLS + 1 + ${#filter}))
      printf '%d' "$cur_col" > "$anim_col_file"
      kill -CONT "$anim_pid" 2>/dev/null || true

      needs_full_redraw=0
    fi

    # Block on read — sidecar handles caret pulse in background.  The
    # `|| true` masks read's non-zero return on EOF / signal interrupt so
    # set -e doesn't unwind the picker; an empty key is then treated as
    # Enter, which is what would normally happen anyway.
    local key=""
    IFS= read -rsn1 key || true

    if [[ -z "$key" ]]; then
      # `read -n1` returns rc=0 with empty $key when the line terminator
      # (Enter) arrives — the delimiter is consumed but not stored.
      if (( n_sel > 0 )); then
        local orig_idx="${vis_idx[$current]}"
        PICKER_RESULT_SLUG="${PICKER_SLUGS[$orig_idx]}"
        PICKER_RESULT_ENTRY="${PICKER_ENTRIES[$orig_idx]}"
      fi
      break
    fi

    case "$key" in
      $'\e')
        # Arrow key (ESC [ A/B) or bare ESC.  Bash 3.2 has no fractional
        # `read -t`; stty min/time peeks the rest of the sequence.
        stty -icanon min 0 time 1
        local seq="" dir=""
        IFS= read -rsn1 seq
        if [[ "$seq" == '[' ]]; then
          IFS= read -rsn1 dir
        fi
        stty -icanon min 1 time 0
        if [[ "$seq" == '[' ]]; then
          case "$dir" in
            A) (( n_sel > 0 )) && cursor=$(( (cursor - 1 + n_sel) % n_sel )) ;;
            B) (( n_sel > 0 )) && cursor=$(( (cursor + 1) % n_sel )) ;;
          esac
        else
          rc=1; break
        fi ;;
      $'\t')
        # Tab: on a row jump to first selectable in the next bucket; on
        # an action item (or anywhere with no bucket) behave like ↓.
        if (( n_sel > 0 )); then
          local _cv="${sel_idx[$cursor]}" _co
          _co="${vis_idx[$_cv]}"
          local _ctype="${PICKER_TYPES[$_co]}" _cbuck="${PICKER_BUCKET[$_co]:-}"
          if [[ "$_ctype" == "action" || -z "$_cbuck" ]]; then
            cursor=$(( (cursor + 1) % n_sel ))
          else
            local _target="$cursor" _k _kv _ko _kb
            for (( _k = 1; _k <= n_sel; _k++ )); do
              local _cand=$(( (cursor + _k) % n_sel ))
              _kv="${sel_idx[$_cand]}"
              _ko="${vis_idx[$_kv]}"
              _kb="${PICKER_BUCKET[$_ko]:-}"
              # First selectable with a different bucket (or no bucket,
              # i.e. an action) — land there.
              if [[ "$_kb" != "$_cbuck" ]]; then
                _target="$_cand"; break
              fi
            done
            cursor="$_target"
          fi
        fi ;;
      $'\x7f'|$'\b')
        filter="${filter%?}"
        filter_lc="${filter_lc%?}"
        cursor=0 ;;
      [[:print:]])
        filter+="$key"
        # tr fork happens once per keypress (human-paced), not per frame.
        filter_lc+=$(printf '%s' "$key" | tr '[:upper:]' '[:lower:]')
        cursor=0 ;;
    esac
    needs_full_redraw=1
  done

  # Stop the animator before restoring terminal state.  All three calls
  # tolerate failure — the animator may have died on its own already.
  rm -f "$anim_col_file" 2>/dev/null || true
  kill "$anim_pid" 2>/dev/null || true
  wait "$anim_pid" 2>/dev/null || true

  stty "$stty_save" 2>/dev/null || true
  printf '\033[?25h'  # show hardware cursor again
  return $rc
}

# Build picker entries — populates four parallel globals consumed by
# ui_picker:
#   PICKER_ENTRIES    — display lines (ANSI-styled)
#   PICKER_SLUGS      — return key per selectable; sentinels for actions:
#                         __more__<b>  "+N more" expand bucket
#                         __act_add__  "+ Add new"
#                         __act_reload__ reload
#                         __act_exit__ exit
#   PICKER_TYPES      — 'row'|'action'|'header'|'padding'|'summary'
#   PICKER_FILTERABLE — '1' for rows (subject to search filter), '0' for rest
#
# Layout: column header → rows (per bucket, capped + "+N more") → blank
# padding → summary → blank padding → action items.
# Append empty placeholders to all per-row metadata arrays.  Keeps them
# parallel with PICKER_ENTRIES so the picker can index any slot safely.
_picker_meta_empty() {
  PICKER_BUCKET+=("")
  PICKER_TITLE+=("")
  PICKER_TITLE_W+=("0")
  PICKER_LEFT+=("")
  PICKER_RIGHT+=("")
}

build_main_entries() {
  PICKER_ENTRIES=()
  PICKER_SLUGS=()
  PICKER_TYPES=()
  PICKER_FILTERABLE=()
  PICKER_BUCKET=()
  PICKER_TITLE=()
  PICKER_TITLE_W=()
  PICKER_LEFT=()
  PICKER_RIGHT=()

  local rows; rows=$(collect_rows all)

  # Column headers.
  PICKER_ENTRIES+=("$(_build_header_row)")
  PICKER_SLUGS+=("")
  PICKER_TYPES+=("header")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty

  local limit; limit="$(config_get list_per_bucket_limit 3)"
  for b in "${BUCKETS[@]}"; do
    local bucket_rows; bucket_rows=$(printf '%s\n' "$rows" \
      | awk -F'\t' -v b="$b" '$1 == b' \
      | apply_sort "$MAIN_SORT" "$MAIN_REVERSE")
    [[ -z "$bucket_rows" ]] && continue
    local n; n=$(printf '%s\n' "$bucket_rows" | wc -l | tr -d ' ')
    local show="$bucket_rows"
    (( n > limit )) && show=$(printf '%s\n' "$bucket_rows" | head -n "$limit")
    while IFS=$'\t' read -r bb slug title _ upd crt; do
      # Use build_row_parts so we can keep the title-cell data around for
      # filter-match highlighting in the picker.
      build_row_parts "$bb" "$title" "$upd" "$crt"
      local _padded; _padded=$(printf '%-*s' "$ROW_TITLE_W" "$ROW_TITLE")
      PICKER_ENTRIES+=("${ROW_LEFT}$(ui_paint fd_title "$_padded")${ROW_RIGHT}")
      PICKER_SLUGS+=("$slug")
      PICKER_TYPES+=("row")
      PICKER_FILTERABLE+=("1")
      PICKER_BUCKET+=("$bb")
      PICKER_TITLE+=("$ROW_TITLE")
      PICKER_TITLE_W+=("$ROW_TITLE_W")
      PICKER_LEFT+=("$ROW_LEFT")
      PICKER_RIGHT+=("$ROW_RIGHT")
    done <<< "$show"
    if (( n > limit )); then
      PICKER_ENTRIES+=("$(_build_more_row "$b" "$((n - limit))")")
      PICKER_SLUGS+=("__more__$b")
      PICKER_TYPES+=("action")
      # Filterable=1 so "+N more" hides when the user is searching by text
      # (its label "+N more items..." rarely matches a query).
      PICKER_FILTERABLE+=("1")
      # Tag the +N more action with the bucket it belongs to — Tab on the
      # last row of bucket X then lands on the next bucket (not on +N more
      # which still belongs to bucket X).
      PICKER_BUCKET+=("$b")
      PICKER_TITLE+=("")
      PICKER_TITLE_W+=("0")
      PICKER_LEFT+=("")
      PICKER_RIGHT+=("")
      # (Used to insert an empty padding row here for breathing room.
      # Removed in 0.32.5 per user feedback — they asked for half the
      # vertical gap; in a cell-based terminal we can only go to 0 lines,
      # which is the closest reduction available.)
    fi
  done

  # Padding → summary → padding.
  PICKER_ENTRIES+=("")
  PICKER_SLUGS+=("")
  PICKER_TYPES+=("padding")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty

  PICKER_ENTRIES+=("$(_build_summary_row "$(printf '%s\n' "$rows" | wc -l | tr -d ' ')" "$rows")")
  PICKER_SLUGS+=("")
  PICKER_TYPES+=("summary")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty

  PICKER_ENTRIES+=("")
  PICKER_SLUGS+=("")
  PICKER_TYPES+=("padding")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty

  # Action items at bottom (always selectable, never filtered).
  PICKER_ENTRIES+=("$(ui_paint fd_chrome "$ACT_ADD")")
  PICKER_SLUGS+=("__act_add__")
  PICKER_TYPES+=("action")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty

  PICKER_ENTRIES+=("$(ui_paint fd_chrome "$ACT_RELOAD")")
  PICKER_SLUGS+=("__act_reload__")
  PICKER_TYPES+=("action")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty

  PICKER_ENTRIES+=("$(ui_paint fd_chrome "$ACT_EXIT")")
  PICKER_SLUGS+=("__act_exit__")
  PICKER_TYPES+=("action")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty
}

# Interactive REPL — single screen via custom ui_picker:
#   ⌕ Search prompt → column headers → list rows → padding →
#   summary → padding → action items.
# Cursor skips header/padding/summary; only row/action types are selectable.
cmd_interactive() {
  require_foundry
  if [[ "$UI_MODE" != "interactive" ]]; then
    ui_error "no args: pass a subcommand (list/show/new/move/setup) in --plain mode"
    exit 64
  fi

  MAIN_SORT="$(config_get default_sort updated)"
  MAIN_REVERSE=0
  [[ "$(config_get default_reverse false)" == "true" ]] && MAIN_REVERSE=1

  trap 'clear; exit 0' INT

  while true; do
    local rows; rows=$(collect_rows all)

    if [[ -z "$rows" ]]; then
      clear
      ui_header "Foundry" "empty"
      echo
      if gum confirm "Add your first change now?"; then
        ui_add_new
      else
        clear; exit 0
      fi
      continue
    fi

    build_main_entries
    # Branded header above the search prompt — gives the screen identity
    # ("you're in foundry") without redundant chrome.
    PICKER_HEADER="$(build_picker_header)"
    if ui_picker "⌕ Search "; then
      local slug="$PICKER_RESULT_SLUG"
      case "$slug" in
        __more__*)
          ui_bucket_view "${slug#__more__}" ;;
        __act_add__)
          ui_add_new ;;
        __act_reload__)
          : ;;   # loop back, rebuild entries
        __act_exit__)
          if gum confirm "Exit foundry?"; then clear; exit 0; fi ;;
        '')
          : ;;   # non-selectable somehow — re-render
        *)
          ui_drill "$slug" ;;
      esac
    else
      # esc — confirm exit
      if gum confirm "Exit foundry?"; then clear; exit 0; fi
    fi
  done
}

# ── dispatch ──────────────────────────────────────────────────────────────
main() {
  if [[ $# -eq 0 ]]; then
    cmd_interactive
    return
  fi
  local sub="$1"; shift
  case "$sub" in
    list)            cmd_list "$@" ;;
    show)            cmd_show "$@" ;;
    new)             cmd_new "$@" ;;
    move)            cmd_move "$@" ;;
    setup)           cmd_setup "$@" ;;
    -h|--help|help)  usage ;;
    *)               ui_error "unknown subcommand: $sub"; usage ;;
  esac
}

main "$@"
