#!/usr/bin/env bash
# foundry — CLI front-end for the change-lifecycle backend.
#
# Two modes:
#   interactive   — default in a TTY; uses gum for icons/colors/prompts
#   --plain       — deterministic output for Claude Code or pipelines
#                   (also auto-enabled when stdout isn't a TTY)
#
# All state mutations go through scripts/change.sh.

set -euo pipefail
export LC_ALL="${LC_ALL:-en_US.UTF-8}"

# ── locate ourselves (resolve symlink chain so .foundry/cli pointing
# back at the plugin works the same as a direct call). cli lives at
# the plugin root, so resolve_self() IS the plugin root. ──────────────────
resolve_self() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local tgt; tgt="$(readlink "$src")"
    if [[ "$tgt" = /* ]]; then src="$tgt"
    else src="$(dirname "$src")/$tgt"
    fi
  done
  cd "$(dirname "$src")" && pwd
}
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(resolve_self)}"
SCRIPTS="$PLUGIN_ROOT/scripts"
CHANGE_SH="$SCRIPTS/change.sh"
SETUP_SH="$SCRIPTS/setup.sh"
TRACKING_SH="$SCRIPTS/tracking.sh"

# ── parse --plain anywhere in the args ────────────────────────────────────
ARGS=()
for arg in "$@"; do
  if [[ "$arg" == "--plain" ]]; then
    export FOUNDRY_PLAIN=1
  else
    ARGS+=("$arg")
  fi
done
set -- "${ARGS[@]+"${ARGS[@]}"}"

# shellcheck source=../scripts/lib/ui.sh
. "$SCRIPTS/lib/ui.sh"
# shellcheck source=../scripts/lib/constants.sh
. "$SCRIPTS/lib/constants.sh"
# shellcheck source=../scripts/lib/config.sh
. "$SCRIPTS/lib/config.sh"

# ── helpers ───────────────────────────────────────────────────────────────
FOUNDRY_ROOT="${FOUNDRY_ROOT:-$PWD/.foundry}"
CHANGES_DIR="$FOUNDRY_ROOT/changes"

usage() {
  cat <<'EOF'
usage:
  foundry                          interactive: pick a change and act
  foundry list [--bucket=X]        list changes (all or filtered)
  foundry show <slug>              show a change's tracking + history
  foundry new ["title"]            create a change (asks for title if omitted)
  foundry move <slug> [--to=X] [--reason=R]
                                   move a change between buckets
  foundry setup                    scaffold .foundry/ in the current project

global flags:
  --plain                          ASCII output, no prompts
EOF
  exit 64
}

require_foundry() {
  [[ -d "$CHANGES_DIR" ]] || { ui_error "no .foundry/ — run: foundry setup"; exit 2; }
}

# Echo bucket containing slug or empty + exit 1.
find_bucket() {
  local slug="$1"
  for b in "${BUCKETS[@]}"; do
    [[ -d "$CHANGES_DIR/$b/$slug" ]] && { echo "$b"; return 0; }
  done
  return 1
}

# Compute "age" string from a tracking.yaml updated_at field.
age_of() {
  local dir="$1"
  local ts; ts=$("$TRACKING_SH" get "$dir" updated_at 2>/dev/null) || return 0
  [[ -z "$ts" ]] && return 0
  local now; now=$(date -u +%s)
  local then
  if then=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$ts" +%s 2>/dev/null); then
    :
  elif then=$(date -u -d "$ts" +%s 2>/dev/null); then
    :
  else
    echo "?"; return 0
  fi
  local delta=$((now - then))
  if   (( delta < 60 ));      then echo "${delta}s"
  elif (( delta < 3600 ));    then echo "$((delta / 60))m"
  elif (( delta < 86400 ));   then echo "$((delta / 3600))h"
  elif (( delta < 604800 ));  then echo "$((delta / 86400))d"
  else                              echo "$((delta / 604800))w"
  fi
}

# Emit a TSV row per change: bucket\tslug\ttitle\tage\tupdated_at_epoch
# Last column is for sorting; consumers strip it.
collect_rows() {
  local filter="${1:-all}"
  local buckets=("${BUCKETS[@]}")
  [[ "$filter" != "all" ]] && buckets=("$filter")
  shopt -s nullglob
  for b in "${buckets[@]}"; do
    [[ -d "$CHANGES_DIR/$b" ]] || continue
    for entry in "$CHANGES_DIR/$b"/*/; do
      local slug; slug=$(basename "$entry")
      local title; title=$("$TRACKING_SH" get "$entry" title 2>/dev/null || echo "?")
      local age;   age=$(age_of "$entry")
      local ts;    ts=$("$TRACKING_SH" get "$entry" updated_at 2>/dev/null || echo "")
      local epoch=0
      if [[ -n "$ts" ]]; then
        epoch=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$ts" +%s 2>/dev/null \
              || date -u -d "$ts" +%s 2>/dev/null || echo 0)
      fi
      printf '%s\t%s\t%s\t%s\t%s\n' "$b" "$slug" "$title" "$age" "$epoch"
    done
  done
  shopt -u nullglob
}

# ── subcommands ───────────────────────────────────────────────────────────

# Render a single row of the list (icon + slug + title + age, all
# padded/colored). Used by both the grouped renderer and --bucket flat.
render_row() {
  local b="$1" slug="$2" title="$3" epoch="$4"
  local slug_w="$5" title_w="$6" upd_w="$7"

  local rel="?"
  if [[ "$epoch" != "0" ]]; then
    local iso
    iso=$(date -u -r "$epoch" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null \
       || date -u -d "@$epoch" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || echo "")
    [[ -n "$iso" ]] && rel=$(ui_date_relative "$iso")
  fi
  local s_t; s_t=$(ui_truncate "$slug_w" "$slug")
  local t_t; t_t=$(ui_truncate "$title_w" "$title")
  printf '  %s  %s  %s  %s\n' \
    "$(ui_status_icon "$b")" \
    "$(ui_bright "$(printf '%-*s' "$slug_w" "$s_t")")" \
    "$(printf '%-*s' "$title_w" "$t_t")" \
    "$(ui_dim "$(printf '%-*s' "$upd_w" "$rel")")"
}

# Apply --sort within a set of rows.
apply_sort() {
  local sort="$1" reverse="$2"
  local order_flag="-r"; [[ "$reverse" == "1" ]] && order_flag=""
  case "$sort" in
    updated|created) sort -t$'\t' -k5 -n $order_flag ;;
    slug)            sort -t$'\t' -k2 $order_flag ;;
    title)           sort -t$'\t' -k3 -f $order_flag ;;
    *)               cat ;;
  esac
}

# Resolve column widths from terminal size.
col_widths() {
  local cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 100)}
  (( cols > 120 )) && cols=120
  local slug_w=28 upd_w=12
  local title_w=$(( cols - 4 - slug_w - 2 - upd_w - 4 ))
  (( title_w < 20 )) && title_w=20
  printf '%d %d %d' "$slug_w" "$title_w" "$upd_w"
}

# Render one bucket section: divider with name + count, capped rows,
# "⋯ +N more" footer when truncated. Skips empty buckets.
render_bucket_section() {
  local b="$1" all_rows="$2" sort="$3" reverse="$4" limit="$5"
  local bucket_rows; bucket_rows=$(printf '%s\n' "$all_rows" | awk -F'\t' -v b="$b" '$1 == b')
  [[ -z "$bucket_rows" ]] && return

  local n; n=$(printf '%s\n' "$bucket_rows" | wc -l | tr -d ' ')

  printf '\n'
  ui_divider "$(ui_status "$b") · $n"

  bucket_rows=$(printf '%s\n' "$bucket_rows" | apply_sort "$sort" "$reverse")

  local show="$bucket_rows"
  if (( n > limit )); then
    show=$(printf '%s\n' "$bucket_rows" | head -n "$limit")
  fi

  read -r slug_w title_w upd_w <<< "$(col_widths)"
  while IFS=$'\t' read -r bb slug title _ epoch; do
    render_row "$bb" "$slug" "$title" "$epoch" "$slug_w" "$title_w" "$upd_w"
  done <<< "$show"

  if (( n > limit )); then
    local more=$((n - limit))
    printf '  %s  %s\n' \
      "$(ui_dim '⋯')" \
      "$(ui_dim "+$more more in $b — foundry list --bucket=$b")"
  fi
}

cmd_list() {
  require_foundry
  local filter="all" sort
  sort="$(config_get default_sort updated)"
  local reverse=0
  [[ "$(config_get default_reverse false)" == "true" ]] && reverse=1

  for arg in "$@"; do
    case "$arg" in
      --bucket=*) filter="${arg#--bucket=}" ;;
      --sort=*)   sort="${arg#--sort=}" ;;
      --reverse)  reverse=1 ;;
      *) ui_error "unknown flag: $arg"; exit 64 ;;
    esac
  done

  case "$sort" in
    updated|created|slug|title) ;;
    *) ui_error "--sort must be one of: updated, created, slug, title"; exit 64 ;;
  esac

  local rows; rows=$(collect_rows all)

  if [[ -z "$rows" ]]; then
    ui_header "Foundry" "empty"
    ui_info "get started: foundry new \"your idea\""
    echo
    return 0
  fi

  local total; total=$(printf '%s\n' "$rows" | wc -l | tr -d ' ')
  local arrow; (( reverse )) && arrow='↑' || arrow='↓'

  if [[ "$filter" != "all" ]]; then
    # single-bucket view — no grouping, no cap.
    local bucket_rows; bucket_rows=$(printf '%s\n' "$rows" | awk -F'\t' -v b="$filter" '$1 == b')
    local n=0
    [[ -n "$bucket_rows" ]] && n=$(printf '%s\n' "$bucket_rows" | wc -l | tr -d ' ')
    if (( n == 0 )); then
      ui_header "Foundry" "$(ui_status "$filter") · empty"
      echo
      return 0
    fi
    ui_header "Foundry" "$(ui_status "$filter") · $n · sort: $sort $arrow"
    read -r slug_w title_w upd_w <<< "$(col_widths)"
    while IFS=$'\t' read -r bb slug title _ epoch; do
      render_row "$bb" "$slug" "$title" "$epoch" "$slug_w" "$title_w" "$upd_w"
    done < <(printf '%s\n' "$bucket_rows" | apply_sort "$sort" "$reverse")
    echo
    return 0
  fi

  # Grouped view: summary line + section per non-empty bucket.
  local breakdown=""
  for b in "${BUCKETS[@]}"; do
    local cnt; cnt=$(printf '%s\n' "$rows" | awk -F'\t' -v b="$b" '$1 == b' | wc -l | tr -d ' ')
    breakdown+="$(ui_status_icon "$b") $cnt  "
  done
  ui_header "Foundry" "$total · ${breakdown% } · sort: $sort $arrow"
  local limit; limit="$(config_get list_per_bucket_limit 3)"
  for b in "${BUCKETS[@]}"; do
    render_bucket_section "$b" "$rows" "$sort" "$reverse" "$limit"
  done
  echo

  if [[ "$UI_MODE" == "interactive" ]]; then
    printf '  %s  %s\n' \
      "$(ui_dim 'open      :')" "$(ui_dim 'foundry show <slug>')"
    printf '  %s  %s\n' \
      "$(ui_dim 'add       :')" "$(ui_dim 'foundry new "your idea"')"
    printf '  %s  %s\n' \
      "$(ui_dim 'one bucket:')" "$(ui_dim 'foundry list --bucket=<status>')"
    printf '  %s  %s\n' \
      "$(ui_dim 'configure :')" "$(ui_dim '.foundry/config.yaml')"
    echo
  fi
}

cmd_show() {
  require_foundry
  local slug="${1:-}"
  [[ -n "$slug" ]] || { ui_error "show: missing slug"; exit 64; }
  local b
  if ! b=$(find_bucket "$slug" 2>/dev/null); then
    ui_error "not found: $slug"
    # offer near matches
    local hits
    hits=$(collect_rows all 2>/dev/null | awk -F'\t' -v q="$slug" '
      BEGIN { lq = tolower(q) }
      index(tolower($2), lq) > 0 || index(tolower($3), lq) > 0 { print $0 }
    ' | head -5)
    if [[ -n "$hits" ]]; then
      echo
      ui_info "did you mean:"
      while IFS=$'\t' read -r bb ss tt _ _; do
        printf '    %s  %s  %s\n' \
          "$(ui_status_icon "$bb")" \
          "$(ui_bright "$ss")" \
          "$(ui_dim "$tt")"
      done <<< "$hits"
      echo
    fi
    exit 1
  fi
  local dir="$CHANGES_DIR/$b/$slug"

  local title;   title=$("$TRACKING_SH" get "$dir" title 2>/dev/null)
  local status;  status=$("$TRACKING_SH" get "$dir" status 2>/dev/null)
  local created; created=$("$TRACKING_SH" get "$dir" created_at 2>/dev/null)
  local updated; updated=$("$TRACKING_SH" get "$dir" updated_at 2>/dev/null)
  local reason;  reason=$("$TRACKING_SH" get "$dir" decline_reason 2>/dev/null || true)

  # ── header: icon + slug, then title as h1, then metadata ──
  echo
  printf '  %s  %s\n' "$(ui_status_icon "$b")" "$(ui_bright "$slug")"
  printf '  %s\n' "$title"
  echo
  ui_kv 10 "status"  "$status"
  ui_kv 10 "updated" "$(ui_date_relative "$updated") · $(ui_date_short "$updated")"
  ui_kv 10 "created" "$(ui_date_short "$created")"
  [[ -n "$reason" ]] && ui_kv 10 "reason" "$reason"
  echo

  # ── proposal preview: first N content lines, dim, blanks collapsed ──
  if [[ -f "$dir/proposal.md" ]]; then
    ui_divider "proposal"
    local n=12
    local shown=0 total_content
    total_content=$(grep -cE '[^[:space:]]' "$dir/proposal.md" || echo 0)
    grep -E '[^[:space:]]' "$dir/proposal.md" | head -n "$n" | while IFS= read -r line; do
      printf '  %s\n' "$(ui_dim "$line")"
    done
    if (( total_content > n )); then
      printf '  %s\n' "$(ui_dim "  … $((total_content - n)) more lines in proposal.md")"
    fi
    echo
  fi

  # ── history: log-style, newest first ──
  if [[ -f "$dir/history.log" ]]; then
    ui_divider "history"
    {
      tac "$dir/history.log" 2>/dev/null || tail -r "$dir/history.log"
    } | head -10 | while IFS=$'\t' read -r ts actor event details; do
      local rel; rel=$(ui_date_relative "$ts")
      local actor_color=muted
      [[ "$actor" == "user" ]] && actor_color=ok
      [[ "$actor" == "state-machine" ]] && actor_color=accent
      # Pretty details: "backlog->declined (reason)" → "backlog → declined"
      # with reason rendered as a second indented line.
      local pretty="$details" reason_line=""
      pretty="${pretty//->/ → }"
      if [[ "$pretty" =~ ^(.+)\ \((.+)\)$ ]]; then
        pretty="${BASH_REMATCH[1]}"
        reason_line="${BASH_REMATCH[2]}"
      fi
      printf '  %s  %s  %s  %s\n' \
        "$(ui_dim "$(printf '%-12s' "$rel")")" \
        "$(ui_paint "$actor_color" "$(printf '%-14s' "$actor")")" \
        "$(ui_bright "$(printf '%-8s' "$event")")" \
        "$pretty"
      if [[ -n "$reason_line" ]]; then
        printf '  %s  %s  %s  %s\n' \
          "            " "              " "        " \
          "$(ui_dim "\"$reason_line\"")"
      fi
    done
    echo
  fi

  # ── next actions ──
  if [[ "$UI_MODE" == "interactive" ]]; then
    ui_divider "next"
    case "$b" in
      backlog)
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=in-progress")" "$(ui_dim '— start')"
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=declined --reason=\"…\"")" "$(ui_dim '— decline')"
        ;;
      in-progress)
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=done")" "$(ui_dim '— finish')"
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=backlog")" "$(ui_dim '— pause')"
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=declined --reason=\"…\"")" "$(ui_dim '— decline')"
        ;;
      done)
        printf '  %s\n' "$(ui_dim '(terminal — no transitions out)')"
        ;;
      declined)
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=backlog")" "$(ui_dim '— revive')"
        ;;
    esac
    echo
  fi
}

cmd_new() {
  local title="${1:-}"
  if [[ -z "$title" ]]; then
    if [[ "$UI_MODE" == "interactive" ]]; then
      title=$(ui_input "Change title (free text)")
      [[ -z "$title" ]] && { ui_error "title required"; exit 1; }
    else
      ui_error "new: title required as argument in --plain mode"
      exit 64
    fi
  fi

  # Slug generation: ASCII-fold the title, kebab-case it. Caller can
  # override by passing FOUNDRY_SLUG=... env (used by Claude Code when
  # it wants to LLM-pick a semantic slug).
  local slug="${FOUNDRY_SLUG:-}"
  if [[ -z "$slug" ]]; then
    slug=$(printf '%s' "$title" \
      | iconv -f utf-8 -t ascii//translit 2>/dev/null \
      | tr '[:upper:]' '[:lower:]' \
      | tr -c 'a-z0-9' '-' \
      | sed -E 's/-+/-/g; s/^-+|-+$//g' \
      | cut -c1-40)
    [[ -z "$slug" ]] && slug="change-$(date +%s)"
  fi

  require_foundry
  "$CHANGE_SH" new "$slug" "$title" >/dev/null
  ui_header "$(ui_status_icon backlog) $slug" "created in backlog"
  ui_info "edit: .foundry/changes/backlog/$slug/proposal.md"
  echo
}

cmd_move() {
  require_foundry
  local slug="${1:-}"
  [[ -n "$slug" ]] || { ui_error "move: missing slug"; exit 64; }
  shift

  local to="" reason=""
  for arg in "$@"; do
    case "$arg" in
      --to=*)     to="${arg#--to=}" ;;
      --reason=*) reason="${arg#--reason=}" ;;
      *) ui_error "unknown flag: $arg"; exit 64 ;;
    esac
  done

  local from; from=$(find_bucket "$slug") || { ui_error "not found: $slug"; exit 1; }

  if [[ -z "$to" ]]; then
    if [[ "$UI_MODE" == "interactive" ]]; then
      # offer all buckets except current
      local opts=()
      for b in "${BUCKETS[@]}"; do
        [[ "$b" == "$from" ]] && continue
        opts+=("$(ui_icon "$b") $b")
      done
      local pick; pick=$(ui_choose "Move $slug from $(ui_icon "$from") $from to:" "${opts[@]}") || exit 1
      to="${pick#* }"
    else
      ui_error "move: --to=<bucket> required in --plain mode"
      exit 64
    fi
  fi

  if [[ "$to" == "declined" && -z "$reason" ]]; then
    if [[ "$UI_MODE" == "interactive" ]]; then
      reason=$(ui_input "Reason for declining")
      [[ -z "$reason" ]] && { ui_error "decline reason required"; exit 1; }
    else
      ui_error "move to declined: --reason=... required in --plain mode"
      exit 64
    fi
  fi

  local out
  if out=$("$CHANGE_SH" move "$slug" "$to" ${reason:+"$reason"} 2>&1); then
    printf '\n  %s  %s  %s %s %s\n\n' \
      "$(ui_paint ok '✓')" \
      "$(ui_bright "$slug")" \
      "$(ui_status_icon "$from")" \
      "$(ui_dim '→')" \
      "$(ui_status "$to")"
  else
    printf '%s\n' "$out" >&2
    exit 1
  fi
}

cmd_setup() {
  bash "$SETUP_SH" "$@"
}

# Build the picker row format used by `gum filter`.
build_picker_line() {
  local b="$1" slug="$2" title="$3" epoch="$4"
  local rel="?"
  if [[ "$epoch" != "0" ]]; then
    local iso
    iso=$(date -u -r "$epoch" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null \
       || date -u -d "@$epoch" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || echo "")
    [[ -n "$iso" ]] && rel=$(ui_date_relative "$iso")
  fi
  printf '%s  %-28s  %-40s  %s\n' \
    "$(ui_icon "$b")" \
    "$(ui_truncate 28 "$slug")" \
    "$(ui_truncate 40 "$title")" \
    "$rel"
}

# Press-any-key gate; used between an action's output and the next redraw.
pause_for_user() {
  printf '\n  %s ' "$(ui_dim 'press ↵ to continue')"
  read -r _ || true
}

# Pick a change → show → action menu.
ui_pick_and_act() {
  local rows; rows=$(collect_rows all | sort -t$'\t' -k5 -nr)
  [[ -z "$rows" ]] && return

  local lines=()
  while IFS=$'\t' read -r b slug title _ epoch; do
    lines+=("$(build_picker_line "$b" "$slug" "$title" "$epoch")")
  done <<< "$rows"

  local pick
  pick=$(printf '%s\n' "${lines[@]}" \
    | gum filter --header "Pick a change (type to filter)" --indicator='▸') || return

  local slug; slug=$(printf '%s' "$pick" | awk '{print $2}')
  [[ -z "$slug" ]] && return

  clear
  cmd_show "$slug"

  local b; b=$(find_bucket "$slug") || { pause_for_user; return; }
  local actions=()
  case "$b" in
    backlog)     actions=("▸ Start (move to in-progress)" "▸ Decline" "─ Back") ;;
    in-progress) actions=("▸ Finish (move to done)" "▸ Pause back to backlog" "▸ Decline" "─ Back") ;;
    done)        actions=("─ Back (terminal — no transitions out)") ;;
    declined)    actions=("▸ Revive (back to backlog)" "─ Back") ;;
  esac
  local action
  action=$(gum choose --header "What next?" "${actions[@]}") || return

  case "$action" in
    *"Start"*)
      cmd_move "$slug" --to=in-progress
      pause_for_user ;;
    *"Finish"*)
      cmd_move "$slug" --to=done
      pause_for_user ;;
    *"Pause"*)
      cmd_move "$slug" --to=backlog
      pause_for_user ;;
    *"Revive"*)
      cmd_move "$slug" --to=backlog
      pause_for_user ;;
    *"Decline"*)
      local reason
      reason=$(gum input --placeholder "Reason for declining" --header "Decline $slug")
      if [[ -n "$reason" ]]; then
        cmd_move "$slug" --to=declined --reason="$reason"
        pause_for_user
      fi ;;
    *) ;;  # Back / cancel — silent
  esac
}

# Prompt for a title, then create.
ui_add_new() {
  clear
  ui_header "Foundry" "new change"
  local title
  title=$(gum input --placeholder "Change title (free text)" --width 60)
  [[ -z "$title" ]] && return
  cmd_new "$title"
  pause_for_user
}

# Reconfigure the sort/reverse pair for the current session.
ui_sort_picker() {
  local choice
  choice=$(gum choose --header "Sort by..." \
    "updated · newest first" \
    "updated · oldest first" \
    "created · newest first" \
    "created · oldest first" \
    "slug · A → Z" \
    "slug · Z → A" \
    "title · A → Z" \
    "title · Z → A") || return
  case "$choice" in
    "updated · newest first") MAIN_SORT=updated; MAIN_REVERSE=0 ;;
    "updated · oldest first") MAIN_SORT=updated; MAIN_REVERSE=1 ;;
    "created · newest first") MAIN_SORT=created; MAIN_REVERSE=0 ;;
    "created · oldest first") MAIN_SORT=created; MAIN_REVERSE=1 ;;
    "slug · A → Z")           MAIN_SORT=slug;    MAIN_REVERSE=0 ;;
    "slug · Z → A")           MAIN_SORT=slug;    MAIN_REVERSE=1 ;;
    "title · A → Z")          MAIN_SORT=title;   MAIN_REVERSE=0 ;;
    "title · Z → A")          MAIN_SORT=title;   MAIN_REVERSE=1 ;;
  esac
}

# Interactive REPL — main entry when called with no args in a TTY.
cmd_interactive() {
  require_foundry
  if [[ "$UI_MODE" != "interactive" ]]; then
    ui_error "no args: pass a subcommand (list/show/new/move/setup) in --plain mode"
    exit 64
  fi

  MAIN_SORT="$(config_get default_sort updated)"
  MAIN_REVERSE=0
  [[ "$(config_get default_reverse false)" == "true" ]] && MAIN_REVERSE=1

  trap 'clear; exit 0' INT
  local esc_streak=0

  while true; do
    clear
    cmd_list --sort="$MAIN_SORT" $([[ "$MAIN_REVERSE" == 1 ]] && echo --reverse)

    local action
    if action=$(gum choose --header "" --cursor='▸ ' --cursor-prefix='' \
                  "▸ Pick a change" \
                  "+ Add new change" \
                  "⇅ Sort: $MAIN_SORT $([[ "$MAIN_REVERSE" == 1 ]] && echo '↑' || echo '↓')" \
                  "⟳ Reload" \
                  "✗ Exit"); then
      esc_streak=0
      case "$action" in
        *"Pick"*)     ui_pick_and_act ;;
        *"Add new"*)  ui_add_new ;;
        *"Sort"*)     ui_sort_picker ;;
        *"Reload"*)   ;;
        *"Exit"*)
          if gum confirm "Exit foundry?"; then clear; exit 0; fi ;;
      esac
    else
      esc_streak=$((esc_streak + 1))
      if (( esc_streak >= 2 )); then
        if gum confirm "Exit foundry?"; then clear; exit 0; fi
        esc_streak=0
      fi
      # first esc: silently re-render
    fi
  done
}

# ── dispatch ──────────────────────────────────────────────────────────────
main() {
  if [[ $# -eq 0 ]]; then
    cmd_interactive
    return
  fi
  local sub="$1"; shift
  case "$sub" in
    list)            cmd_list "$@" ;;
    show)            cmd_show "$@" ;;
    new)             cmd_new "$@" ;;
    move)            cmd_move "$@" ;;
    setup)           cmd_setup "$@" ;;
    -h|--help|help)  usage ;;
    *)               ui_error "unknown subcommand: $sub"; usage ;;
  esac
}

main "$@"
