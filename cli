#!/usr/bin/env bash
# foundry — CLI front-end for the change-lifecycle backend.
#
# Two modes:
#   interactive   — default in a TTY; uses gum for icons/colors/prompts
#   --plain       — deterministic output for Claude Code or pipelines
#                   (also auto-enabled when stdout isn't a TTY)
#
# All state mutations go through scripts/change.sh.

set -euo pipefail
export LC_ALL="${LC_ALL:-en_US.UTF-8}"

# ── locate ourselves (resolve symlink chain so .foundry/cli pointing
# back at the plugin works the same as a direct call). cli lives at
# the plugin root, so resolve_self() IS the plugin root. ──────────────────
resolve_self() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local tgt; tgt="$(readlink "$src")"
    if [[ "$tgt" = /* ]]; then src="$tgt"
    else src="$(dirname "$src")/$tgt"
    fi
  done
  cd "$(dirname "$src")" && pwd
}
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(resolve_self)}"
SCRIPTS="$PLUGIN_ROOT/scripts"
CHANGE_SH="$SCRIPTS/change.sh"
SETUP_SH="$SCRIPTS/setup.sh"
TRACKING_SH="$SCRIPTS/tracking.sh"

# ── parse --plain anywhere in the args ────────────────────────────────────
ARGS=()
for arg in "$@"; do
  if [[ "$arg" == "--plain" ]]; then
    export FOUNDRY_PLAIN=1
  else
    ARGS+=("$arg")
  fi
done
set -- "${ARGS[@]+"${ARGS[@]}"}"

# shellcheck source=../scripts/lib/ui.sh
. "$SCRIPTS/lib/ui.sh"
# shellcheck source=../scripts/lib/constants.sh
. "$SCRIPTS/lib/constants.sh"
# shellcheck source=../scripts/lib/config.sh
. "$SCRIPTS/lib/config.sh"
# shellcheck source=../scripts/lib/index.sh
. "$SCRIPTS/lib/index.sh"

# ── helpers ───────────────────────────────────────────────────────────────
FOUNDRY_ROOT="${FOUNDRY_ROOT:-$PWD/.foundry}"
CHANGES_DIR="$FOUNDRY_ROOT/changes"

usage() {
  cat <<'EOF'
usage:
  foundry                          interactive: pick a change and act
  foundry list [--bucket=X]        list changes (all or filtered)
  foundry show <slug>              show a change's tracking + history
  foundry new ["title"]            create a change (asks for title if omitted)
  foundry move <slug> [--to=X] [--reason=R]
                                   move a change between buckets
  foundry sync                     rebuild per-bucket index caches (run after
                                   manual edits inside .foundry/changes/)
  foundry setup                    scaffold .foundry/ in the current project

global flags:
  --plain                          ASCII output, no prompts
EOF
  exit 64
}

require_foundry() {
  [[ -d "$CHANGES_DIR" ]] || { ui_error "no .foundry/ — run: foundry setup"; exit 2; }
}

# Echo bucket containing slug or empty + exit 1.
find_bucket() {
  local slug="$1"
  for b in "${BUCKETS[@]}"; do
    [[ -d "$CHANGES_DIR/$b/$slug" ]] && { echo "$b"; return 0; }
  done
  return 1
}

# Emit a TSV row per change:
#   bucket  slug  title  age_str  updated_epoch  created_epoch
#
# Reads from per-bucket .index.yaml (built by scripts/lib/index.sh) —
# one awk fork per bucket instead of N×3 grep|sed forks per slug.
# When an expected index is missing (first launch after upgrade, or
# someone deleted the file) we rebuild it lazily before reading; the
# explicit `foundry sync` action item rebuilds all four unconditionally.
collect_rows() {
  local filter="${1:-all}"
  local buckets=("${BUCKETS[@]}")
  [[ "$filter" != "all" ]] && buckets=("$filter")
  local now; now=$(date -u +%s)
  local b slug title ct ut ce ue delta age
  for b in "${buckets[@]}"; do
    [[ -d "$CHANGES_DIR/$b" ]] || continue
    [[ -f "$CHANGES_DIR/$b/.index.yaml" ]] || index_rebuild_bucket "$b"
    while IFS=$'\t' read -r slug title ct ut ce ue; do
      [[ -z "$slug" ]] && continue
      if [[ "$ue" != "0" && -n "$ue" ]]; then
        delta=$(( now - ue ))
        if   (( delta < 60 ));     then age="${delta}s"
        elif (( delta < 3600 ));   then age="$(( delta / 60 ))m"
        elif (( delta < 86400 ));  then age="$(( delta / 3600 ))h"
        elif (( delta < 604800 )); then age="$(( delta / 86400 ))d"
        else                            age="$(( delta / 604800 ))w"
        fi
      else
        age="?"
      fi
      printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$b" "$slug" "$title" "$age" "$ue" "$ce"
    done < <(index_read_bucket "$b")
  done
}

# ── subcommands ───────────────────────────────────────────────────────────

# Render a single row of the list (icon + slug + title + age, all
# padded/colored). Used by both the grouped renderer and --bucket flat.
render_row() {
  local b="$1" slug="$2" title="$3" epoch="$4"
  local slug_w="$5" title_w="$6" upd_w="$7"

  local rel="?"
  if [[ "$epoch" != "0" ]]; then
    local iso
    iso=$(date -u -r "$epoch" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null \
       || date -u -d "@$epoch" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || echo "")
    [[ -n "$iso" ]] && rel=$(ui_date_relative "$iso")
  fi
  local s_t; s_t=$(ui_truncate "$slug_w" "$slug")
  local t_t; t_t=$(ui_truncate "$title_w" "$title")
  printf '  %s  %s  %s  %s\n' \
    "$(ui_status_icon "$b")" \
    "$(ui_bright "$(printf '%-*s' "$slug_w" "$s_t")")" \
    "$(ui_paint fd_title "$(printf '%-*s' "$title_w" "$t_t")")" \
    "$(ui_paint fd_updated "$(printf '%-*s' "$upd_w" "$rel")")"
}

# Apply --sort within a set of rows.
apply_sort() {
  local sort="$1" reverse="$2"
  local order_flag="-r"; [[ "$reverse" == "1" ]] && order_flag=""
  case "$sort" in
    updated) sort -t$'\t' -k5 -n $order_flag ;;
    created) sort -t$'\t' -k6 -n $order_flag ;;
    slug)    sort -t$'\t' -k2 $order_flag ;;
    title)   sort -t$'\t' -k3 -f $order_flag ;;
    *)       cat ;;
  esac
}

# Resolve column widths from terminal size.
col_widths() {
  local cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 100)}
  (( cols > 120 )) && cols=120
  local slug_w=28 upd_w=12
  local title_w=$(( cols - 4 - slug_w - 2 - upd_w - 4 ))
  (( title_w < 20 )) && title_w=20
  printf '%d %d %d' "$slug_w" "$title_w" "$upd_w"
}

# Render one bucket section: divider with name + count, capped rows,
# "⋯ +N more" footer when truncated. Skips empty buckets.
render_bucket_section() {
  local b="$1" all_rows="$2" sort="$3" reverse="$4" limit="$5"
  local bucket_rows; bucket_rows=$(printf '%s\n' "$all_rows" | awk -F'\t' -v b="$b" '$1 == b')
  [[ -z "$bucket_rows" ]] && return

  local n; n=$(printf '%s\n' "$bucket_rows" | wc -l | tr -d ' ')

  printf '\n'
  ui_divider "$(ui_status "$b") · $n"

  bucket_rows=$(printf '%s\n' "$bucket_rows" | apply_sort "$sort" "$reverse")

  local show="$bucket_rows"
  if (( n > limit )); then
    show=$(printf '%s\n' "$bucket_rows" | head -n "$limit")
  fi

  read -r slug_w title_w upd_w <<< "$(col_widths)"
  while IFS=$'\t' read -r bb slug title _ upd _crt; do
    render_row "$bb" "$slug" "$title" "$upd" "$slug_w" "$title_w" "$upd_w"
  done <<< "$show"

  if (( n > limit )); then
    local more=$((n - limit))
    printf '  %s  %s\n' \
      "$(ui_dim '⋯')" \
      "$(ui_dim "+$more more in $b — foundry list --bucket=$b")"
  fi
}

cmd_list() {
  require_foundry
  local filter="all" sort
  sort="$(config_get default_sort updated)"
  local reverse=0
  [[ "$(config_get default_reverse false)" == "true" ]] && reverse=1

  for arg in "$@"; do
    case "$arg" in
      --bucket=*) filter="${arg#--bucket=}" ;;
      --sort=*)   sort="${arg#--sort=}" ;;
      --reverse)  reverse=1 ;;
      *) ui_error "unknown flag: $arg"; exit 64 ;;
    esac
  done

  case "$sort" in
    updated|created|slug|title) ;;
    *) ui_error "--sort must be one of: updated, created, slug, title"; exit 64 ;;
  esac

  local rows; rows=$(collect_rows all)

  if [[ -z "$rows" ]]; then
    ui_header "Foundry" "empty"
    ui_info "get started: foundry new \"your idea\""
    echo
    return 0
  fi

  local total; total=$(printf '%s\n' "$rows" | wc -l | tr -d ' ')
  local arrow; (( reverse )) && arrow='↑' || arrow='↓'

  if [[ "$filter" != "all" ]]; then
    # single-bucket view — no grouping, no cap.
    local bucket_rows; bucket_rows=$(printf '%s\n' "$rows" | awk -F'\t' -v b="$filter" '$1 == b')
    local n=0
    [[ -n "$bucket_rows" ]] && n=$(printf '%s\n' "$bucket_rows" | wc -l | tr -d ' ')
    if (( n == 0 )); then
      ui_header "Foundry" "$(ui_status "$filter") · empty"
      echo
      return 0
    fi
    ui_header "Foundry" "$(ui_status "$filter") · $n · sort: $sort $arrow"
    read -r slug_w title_w upd_w <<< "$(col_widths)"
    while IFS=$'\t' read -r bb slug title _ upd _crt; do
      render_row "$bb" "$slug" "$title" "$upd" "$slug_w" "$title_w" "$upd_w"
    done < <(printf '%s\n' "$bucket_rows" | apply_sort "$sort" "$reverse")
    echo
    return 0
  fi

  # Grouped view: summary line + section per non-empty bucket.
  local breakdown=""
  for b in "${BUCKETS[@]}"; do
    local cnt; cnt=$(printf '%s\n' "$rows" | awk -F'\t' -v b="$b" '$1 == b' | wc -l | tr -d ' ')
    breakdown+="$(ui_status_icon "$b") $cnt  "
  done
  ui_header "Foundry" "$total · ${breakdown% } · sort: $sort $arrow"
  local limit; limit="$(config_get list_per_bucket_limit 3)"
  for b in "${BUCKETS[@]}"; do
    render_bucket_section "$b" "$rows" "$sort" "$reverse" "$limit"
  done
  echo

  if [[ "$UI_MODE" == "interactive" ]]; then
    printf '  %s  %s\n' \
      "$(ui_dim 'open      :')" "$(ui_dim 'foundry show <slug>')"
    printf '  %s  %s\n' \
      "$(ui_dim 'add       :')" "$(ui_dim 'foundry new "your idea"')"
    printf '  %s  %s\n' \
      "$(ui_dim 'one bucket:')" "$(ui_dim 'foundry list --bucket=<status>')"
    printf '  %s  %s\n' \
      "$(ui_dim 'configure :')" "$(ui_dim '.foundry/config.yaml')"
    echo
  fi
}

cmd_show() {
  require_foundry
  local slug="${1:-}"
  [[ -n "$slug" ]] || { ui_error "show: missing slug"; exit 64; }
  local b
  if ! b=$(find_bucket "$slug" 2>/dev/null); then
    ui_error "not found: $slug"
    # offer near matches
    local hits
    hits=$(collect_rows all 2>/dev/null | awk -F'\t' -v q="$slug" '
      BEGIN { lq = tolower(q) }
      index(tolower($2), lq) > 0 || index(tolower($3), lq) > 0 { print $0 }
    ' | head -5)
    if [[ -n "$hits" ]]; then
      echo
      ui_info "did you mean:"
      while IFS=$'\t' read -r bb ss tt _ _; do
        printf '    %s  %s  %s\n' \
          "$(ui_status_icon "$bb")" \
          "$(ui_bright "$ss")" \
          "$(ui_dim "$tt")"
      done <<< "$hits"
      echo
    fi
    exit 1
  fi
  local dir="$CHANGES_DIR/$b/$slug"

  local title;   title=$("$TRACKING_SH" get "$dir" title 2>/dev/null)
  local status;  status=$("$TRACKING_SH" get "$dir" status 2>/dev/null)
  local created; created=$("$TRACKING_SH" get "$dir" created_at 2>/dev/null)
  local updated; updated=$("$TRACKING_SH" get "$dir" updated_at 2>/dev/null)
  local reason;  reason=$("$TRACKING_SH" get "$dir" decline_reason 2>/dev/null || true)

  # ── header: icon + slug, then title as h1, then metadata ──
  echo
  printf '  %s  %s\n' "$(ui_status_icon "$b")" "$(ui_paint fd_title "$slug")"
  printf '  %s\n' "$(ui_paint fd_title "$title")"
  echo
  printf '  %s  %s\n' \
    "$(printf '%-10s' "$(ui_dim "status")")" \
    "$(ui_paint "$(ui_bucket_color "$b")" "$status")"
  printf '  %s  %s\n' \
    "$(printf '%-10s' "$(ui_dim "updated")")" \
    "$(ui_paint fd_updated "$(ui_date_relative "$updated") · $(ui_date_full "$updated")")"
  printf '  %s  %s\n' \
    "$(printf '%-10s' "$(ui_dim "created")")" \
    "$(ui_paint fd_created "$(ui_date_full "$created")")"
  [[ -n "$reason" ]] && printf '  %s  %s\n' \
    "$(printf '%-10s' "$(ui_dim "reason")")" \
    "$(ui_paint "$(ui_bucket_color "$b")" "$reason")"
  echo

  # ── proposal preview: first N content lines, dim, blanks collapsed ──
  if [[ -f "$dir/proposal.md" ]]; then
    ui_divider "proposal"
    local n=12
    local shown=0 total_content
    total_content=$(grep -cE '[^[:space:]]' "$dir/proposal.md" || echo 0)
    grep -E '[^[:space:]]' "$dir/proposal.md" | head -n "$n" | while IFS= read -r line; do
      printf '  %s\n' "$(ui_dim "$line")"
    done
    if (( total_content > n )); then
      printf '  %s\n' "$(ui_dim "  … $((total_content - n)) more lines in proposal.md")"
    fi
    echo
  fi

  # ── history: log-style, newest first ──
  if [[ -f "$dir/history.log" ]]; then
    ui_divider "history"
    {
      tac "$dir/history.log" 2>/dev/null || tail -r "$dir/history.log"
    } | head -10 | while IFS=$'\t' read -r ts actor event details; do
      local rel; rel=$(ui_date_relative "$ts")
      local actor_color=muted
      [[ "$actor" == "user" ]] && actor_color=ok
      [[ "$actor" == "state-machine" ]] && actor_color=accent
      # Pretty details: "backlog->declined (reason)" → "backlog → declined"
      # with reason rendered as a second indented line.
      local pretty="$details" reason_line=""
      pretty="${pretty//->/ → }"
      if [[ "$pretty" =~ ^(.+)\ \((.+)\)$ ]]; then
        pretty="${BASH_REMATCH[1]}"
        reason_line="${BASH_REMATCH[2]}"
      fi
      printf '  %s  %s  %s  %s\n' \
        "$(ui_dim "$(printf '%-12s' "$rel")")" \
        "$(ui_paint "$actor_color" "$(printf '%-14s' "$actor")")" \
        "$(ui_bright "$(printf '%-8s' "$event")")" \
        "$pretty"
      if [[ -n "$reason_line" ]]; then
        printf '  %s  %s  %s  %s\n' \
          "            " "              " "        " \
          "$(ui_dim "\"$reason_line\"")"
      fi
    done
    echo
  fi

  # ── next actions ──
  if [[ "$UI_MODE" == "interactive" ]]; then
    ui_divider "next"
    case "$b" in
      backlog)
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=in-progress")" "$(ui_dim '— start')"
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=declined --reason=\"…\"")" "$(ui_dim '— decline')"
        ;;
      in-progress)
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=done")" "$(ui_dim '— finish')"
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=backlog")" "$(ui_dim '— pause')"
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=declined --reason=\"…\"")" "$(ui_dim '— decline')"
        ;;
      done)
        printf '  %s\n' "$(ui_dim '(terminal — no transitions out)')"
        ;;
      declined)
        printf '  %s  %s\n' "$(ui_dim "foundry move $slug --to=backlog")" "$(ui_dim '— revive')"
        ;;
    esac
    echo
  fi
}

cmd_new() {
  local title="${1:-}"
  if [[ -z "$title" ]]; then
    if [[ "$UI_MODE" == "interactive" ]]; then
      title=$(ui_input "Change title (free text)")
      [[ -z "$title" ]] && { ui_error "title required"; exit 1; }
    else
      ui_error "new: title required as argument in --plain mode"
      exit 64
    fi
  fi

  # Slug generation: ASCII-fold the title, kebab-case it. Caller can
  # override by passing FOUNDRY_SLUG=... env (used by Claude Code when
  # it wants to LLM-pick a semantic slug).
  local slug="${FOUNDRY_SLUG:-}"
  if [[ -z "$slug" ]]; then
    slug=$(printf '%s' "$title" \
      | iconv -f utf-8 -t ascii//translit 2>/dev/null \
      | tr '[:upper:]' '[:lower:]' \
      | tr -c 'a-z0-9' '-' \
      | sed -E 's/-+/-/g; s/^-+|-+$//g' \
      | cut -c1-40)
    [[ -z "$slug" ]] && slug="change-$(date +%s)"
  fi

  require_foundry
  "$CHANGE_SH" new "$slug" "$title" >/dev/null
  ui_header "$(ui_status_icon backlog) $slug" "created in backlog"
  ui_info "edit: .foundry/changes/backlog/$slug/proposal.md"
  echo
}

cmd_move() {
  require_foundry
  local slug="${1:-}"
  [[ -n "$slug" ]] || { ui_error "move: missing slug"; exit 64; }
  shift

  local to="" reason=""
  for arg in "$@"; do
    case "$arg" in
      --to=*)     to="${arg#--to=}" ;;
      --reason=*) reason="${arg#--reason=}" ;;
      *) ui_error "unknown flag: $arg"; exit 64 ;;
    esac
  done

  local from; from=$(find_bucket "$slug") || { ui_error "not found: $slug"; exit 1; }

  if [[ -z "$to" ]]; then
    if [[ "$UI_MODE" == "interactive" ]]; then
      # offer all buckets except current
      local opts=()
      for b in "${BUCKETS[@]}"; do
        [[ "$b" == "$from" ]] && continue
        opts+=("$(ui_icon "$b") $b")
      done
      local pick; pick=$(ui_choose "Move $slug from $(ui_icon "$from") $from to:" "${opts[@]}") || exit 1
      to="${pick#* }"
    else
      ui_error "move: --to=<bucket> required in --plain mode"
      exit 64
    fi
  fi

  if [[ "$to" == "declined" && -z "$reason" ]]; then
    if [[ "$UI_MODE" == "interactive" ]]; then
      reason=$(ui_input "Reason for declining")
      [[ -z "$reason" ]] && { ui_error "decline reason required"; exit 1; }
    else
      ui_error "move to declined: --reason=... required in --plain mode"
      exit 64
    fi
  fi

  local out
  if out=$("$CHANGE_SH" move "$slug" "$to" ${reason:+"$reason"} 2>&1); then
    printf '\n  %s  %s  %s %s %s\n\n' \
      "$(ui_paint ok '✓')" \
      "$(ui_bright "$slug")" \
      "$(ui_status_icon "$from")" \
      "$(ui_dim '→')" \
      "$(ui_status "$to")"
  else
    printf '%s\n' "$out" >&2
    exit 1
  fi
}

cmd_setup() {
  bash "$SETUP_SH" "$@"
}

# Full rebuild of all per-bucket .index.yaml files.  Backs the Sync
# action item in the picker and is exposed as a CLI subcommand for
# scripting / cron-style recovery.  In interactive mode a gum spinner
# covers the rebuild; in --plain mode we print a single success line.
cmd_sync() {
  require_foundry
  if [[ "$UI_MODE" == "interactive" ]] && command -v gum >/dev/null 2>&1; then
    gum spin --title "Syncing change indexes…" --spinner dot -- \
      bash -c "
        export FOUNDRY_ROOT='$FOUNDRY_ROOT'
        . '$SCRIPTS/lib/constants.sh'
        . '$SCRIPTS/lib/index.sh'
        index_rebuild_all
      "
  else
    index_rebuild_all
    ui_success "indexes rebuilt"
  fi
}

# Press-any-key gate; used between an action's output and the next redraw.
pause_for_user() {
  printf '\n  %s ' "$(ui_dim 'press ↵ to continue')"
  read -r _ || true
}

# Hand the terminal to a pager so the user can read a full file (the
# proposal.md or history.log behind a "view full" / "+N more" action).
# Two confusion sources in the picker → less handoff in 0.33.0 were:
#   1. the default less prompt "(END)" gave no hint how to exit, leaving
#      users stuck on the file with the picker chrome gone;
#   2. raw markdown with literal "##" / "-" is harder to read than the
#      coloured glyph rendering glow(1) produces.
# Both addressed here:
#   - `glow -s dark` if the file is .md AND glow is installed; cat
#     otherwise.  Output piped into less so we still get scrolling on
#     long files.
#   - less prompt overridden with the visible "press q to return to
#     foundry" string at every state (including end-of-file).
_view_full_with_pager() {
  local file="$1"
  local renderer=cat
  if [[ "$file" == *.md ]] && command -v glow >/dev/null 2>&1; then
    renderer='glow -s dark'
  fi
  # `-R` keeps ANSI from the renderer rendering as colour.
  # `-P` short prompt — applied to all states so the user always sees
  # the exit hint, including the (END) state that used to be opaque.
  $renderer "$file" 2>/dev/null \
    | ${PAGER:-less} -R -P "press q to return to foundry" >/dev/tty
}

# (Action buttons live in a separate bar — see horizontal_action_bar.
# Earlier sentinels SENT_ADD/SORT/RELOAD/EXIT were removed in 0.26.0.)

# Format one change row for the picker (slug NOT displayed — looked up
# via parallel arrays PICKER_ENTRIES + PICKER_SLUGS in cmd_interactive).
# Columns: icon, bucket-text, title, created, updated
# build_row_parts — populate per-row globals consumed by build_full_row and
# by ui_picker (for filter-match title highlighting). Side-effects:
#   ROW_LEFT       — painted "<icon>  <padded bucket>  " (icon in fd_icon)
#   ROW_LEFT_HOVER — same, but icon painted in fd_brand (cursor-on-row)
#   ROW_TITLE      — raw, ANSI-free, truncated title text (unpadded)
#   ROW_TITLE_W    — visual width to pad title to (column alignment)
#   ROW_RIGHT      — painted "  <padded created>  <padded updated>"
# build_full_row composes ROW_LEFT + painted(padded(ROW_TITLE)) + ROW_RIGHT.
# ui_picker, when a filter is active and the title matches, re-paints the
# title slot with highlight ANSI around the match while keeping LEFT/RIGHT
# unchanged.
build_row_parts() {
  local b="$1" title="$2" upd_epoch="$3" crt_epoch="$4"

  local cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 100)}
  (( cols > 140 )) && cols=140
  local bucket_w=12 created_w=18 updated_w=11
  local title_w=$(( cols - bucket_w - created_w - updated_w - 10 ))
  (( title_w < 20 )) && title_w=20

  local created_str updated_str
  if [[ "$crt_epoch" != "0" ]]; then
    local iso; iso=$(date -u -r "$crt_epoch" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null \
                || date -u -d "@$crt_epoch" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null)
    created_str=$(ui_date_full "$iso")
  else
    created_str="?"
  fi
  if [[ "$upd_epoch" != "0" ]]; then
    local iso; iso=$(date -u -r "$upd_epoch" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null \
                || date -u -d "@$upd_epoch" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null)
    updated_str=$(ui_date_relative "$iso")
  else
    updated_str="?"
  fi

  ROW_TITLE=$(ui_truncate "$title_w" "$title")
  ROW_TITLE_W=$title_w
  local _padded_b; _padded_b=$(printf '%-*s' "$bucket_w" "$b")
  local _icon_glyph; _icon_glyph=$(ui_icon "$b")
  ROW_LEFT=$(printf '%s  %s  ' \
    "$(ui_paint fd_icon "$_icon_glyph")" \
    "$(ui_paint "$(ui_bucket_color "$b")" "$_padded_b")")
  # ROW_LEFT_HOVER: same structure, but the status icon paints in
  # fd_brand instead of fd_icon — used when the cursor lands on this
  # row, so icon + title (re-painted in fd_brand by ui_picker) read
  # as a single selector-coloured pair.  Bucket label keeps its per-
  # bucket colour so the bucket identity stays legible.
  ROW_LEFT_HOVER=$(printf '%s  %s  ' \
    "$(ui_paint fd_brand "$_icon_glyph")" \
    "$(ui_paint "$(ui_bucket_color "$b")" "$_padded_b")")
  ROW_RIGHT=$(printf '  %s  %s' \
    "$(ui_paint fd_created "$(printf '%-*s' "$created_w" "$created_str")")" \
    "$(ui_paint fd_updated "$(printf '%-*s' "$updated_w" "$updated_str")")")
}

build_full_row() {
  build_row_parts "$@"
  local padded; padded=$(printf '%-*s' "$ROW_TITLE_W" "$ROW_TITLE")
  printf '%s%s%s' "$ROW_LEFT" "$(ui_paint fd_title "$padded")" "$ROW_RIGHT"
}

# Strip ANSI + trailing whitespace — used to normalize picker rows for
# matching. ui_picker now returns the slug directly, but ui_drill / other
# helpers still use this to clean copy of an entry.
_norm_picker_line() {
  printf '%s' "$1" | sed -E $'s/\033\\[[0-9;]*[a-zA-Z]//g' | sed -E 's/[[:space:]]+$//'
}

# Drill into one change — picker-based detail screen.  Same branded
# header (★ Foundry · subtitle / project: [name]) and ⌕  Search prompt
# as the main screen, with the change's metadata, proposal preview,
# history preview, and an action bar inline as picker entries.  Loops
# until the user picks Back (or ESC) so an action that doesn't leave
# the screen (view full, decline-then-cancel) keeps the same cursor
# position re-rendered fresh.
#
# Plain mode (--plain or non-TTY) falls back to cmd_show + gum choose
# via the legacy path — interactive picker requires TTY for raw input.
ui_drill() {
  local slug="$1"
  while true; do
    local b
    if ! b=$(find_bucket "$slug"); then
      # The change got moved out from under us (e.g. concurrent edit).
      # Bail back to the main screen rather than rendering empty.
      return
    fi
    local dir="$CHANGES_DIR/$b/$slug"

    build_detail_entries "$slug" "$b"

    # Branded header — identical bytes to cmd_interactive so the user
    # sees the same ★ Foundry strip and project line.  Kept in sync by
    # construction (same build_picker_header call, same subtitle text,
    # same _hdr_line2 shape).
    local _project _hdr_line2
    _project=$(basename "$PWD")
    _hdr_line2="$(ui_dim 'project:')  $(ui_paint_bold fd_project "[${_project}]")"
    PICKER_HEADER="$(build_picker_header "$(ui_dim 'Code change registry — propose, track, implement, ship')" "$_hdr_line2")"

    if ui_picker "⌕  Search "; then
      case "$PICKER_RESULT_SLUG" in
        __view_proposal__)
          # _view_full_with_pager: glow-renders the .md if glow is
          # installed, falls back to cat otherwise, and overrides
          # less's prompt with an explicit "press q to return to
          # foundry" hint so the user always sees how to come back.
          _view_full_with_pager "$dir/proposal.md" || true
          ;;
        __view_history__)
          # Same pager wrapper for history.log — tab-separated rows
          # render OK under less, prompt hint applies, and the user
          # gets a chronological audit trail.
          _view_full_with_pager "$dir/history.log" || true
          ;;
        __act_start__)
          cmd_move "$slug" --to=in-progress
          pause_for_user
          ;;
        __act_finish__)
          cmd_move "$slug" --to=done
          pause_for_user
          ;;
        __act_pause__)
          cmd_move "$slug" --to=backlog
          pause_for_user
          ;;
        __act_revive__)
          cmd_move "$slug" --to=backlog
          pause_for_user
          ;;
        __act_decline__)
          local reason
          reason=$(gum input --placeholder "Reason for declining" --header "Decline $slug")
          if [[ -n "$reason" ]]; then
            cmd_move "$slug" --to=declined --reason="$reason"
            pause_for_user
          fi
          ;;
        __act_back__)
          return
          ;;
        '')
          # Empty slug — cursor was on a content row (proposal line
          # or history entry).  Those rows are selectable so the
          # filter can land cursor on them, but Enter is a no-op:
          # loop back, rebuild + re-render, picker re-opens with the
          # same state.  (Slight flicker; functionally a no-op.)
          ;;
        *) ;;
      esac
    else
      # ESC from picker → back to main screen.
      return
    fi
  done
}

# Prompt for a title → create → return (caller redraws).
ui_add_new() {
  clear
  ui_header "Foundry" "new change"
  local title
  title=$(gum input --placeholder "Change title (free text)" --width 60)
  [[ -z "$title" ]] && return
  cmd_new "$title"
  pause_for_user
}

# (Sort picker removed in 0.26.0 per user feedback. Sort is set once
# from .foundry/config.yaml's default_sort.)

# (horizontal_action_bar + render_static_list removed in 0.31.0 — action
# items now live as picker entries handled by ui_picker, no separate mode.)

# Single-bucket paged view (entered from "+N more" row). Reuses ui_picker
# with bucket-specific column header, page summary, and pagination actions.
ui_bucket_view() {
  local bucket="$1"
  # Page size 5 — matches the user-requested pagination cadence and
  # keeps the screen height predictable.  Was 20 previously (with
  # ◀ Previous page / ▶ Next page footer actions); 0.33.3 moved the
  # pagination controls inline as "+N previous" / "+M next" entries
  # that sit at the top/bottom of the list, so the page has to be
  # smaller to actually surface pagination on realistic data sizes.
  local page=1 per_page=5

  while true; do
    local rows; rows=$(collect_rows all | awk -F'\t' -v b="$bucket" '$1 == b' \
                      | apply_sort "$MAIN_SORT" "$MAIN_REVERSE")
    local total=0
    [[ -n "$rows" ]] && total=$(printf '%s\n' "$rows" | wc -l | tr -d ' ')
    (( total == 0 )) && return
    local pages=$(( (total + per_page - 1) / per_page ))
    (( pages < 1 )) && pages=1
    (( page > pages )) && page=$pages
    (( page < 1 )) && page=1
    local start=$(( (page - 1) * per_page + 1 ))
    local end=$(( page * per_page ))
    (( end > total )) && end=$total
    local prev_count=$((start - 1))
    local next_count=$((total - end))
    local page_rows; page_rows=$(printf '%s\n' "$rows" | sed -n "${start},${end}p")

    PICKER_ENTRIES=()
    PICKER_SLUGS=()
    PICKER_TYPES=()
    PICKER_FILTERABLE=()
    PICKER_BUCKET=()
    PICKER_TITLE=()
    PICKER_TITLE_W=()
    PICKER_LEFT=()
    PICKER_LEFT_HOVER=()
    PICKER_RIGHT=()

    # Extra blank row before the column header — matches the main
    # view's breathing space between the ⌕ Search caret and the
    # STATUS / TITLE / CREATED / UPDATED strip.
    PICKER_ENTRIES+=("")
    PICKER_SLUGS+=("")
    PICKER_TYPES+=("padding")
    PICKER_FILTERABLE+=("0")
    _picker_meta_empty

    # Column header.
    PICKER_ENTRIES+=("$(_build_header_row)")
    PICKER_SLUGS+=("")
    PICKER_TYPES+=("header")
    PICKER_FILTERABLE+=("0")
    _picker_meta_empty

    # Blank padding row beneath the column header — matches main view.
    PICKER_ENTRIES+=("")
    PICKER_SLUGS+=("")
    PICKER_TYPES+=("padding")
    PICKER_FILTERABLE+=("0")
    _picker_meta_empty

    # ── inline pagination: "+N previous" at top when page > 1 ──
    # Reuses _build_more_row so the row visually matches the main-
    # screen overflow row (blank icon/bucket cells, label in fd_more
    # across the title cell, blank date cells).  Selecting it pages
    # back; the picker treats it as an action.  Filterable=0 so it
    # stays visible regardless of search text.
    if (( prev_count > 0 )); then
      PICKER_ENTRIES+=("$(_build_more_row "+${prev_count} previous")")
      PICKER_SLUGS+=("__bv_prev__")
      PICKER_TYPES+=("action")
      PICKER_FILTERABLE+=("0")
      _picker_meta_empty
    fi

    # Bucket rows.  Same parts plumbing as build_main_entries so the
    # filter-match title highlighting works here too.
    while IFS=$'\t' read -r bb slug title _ upd crt; do
      build_row_parts "$bb" "$title" "$upd" "$crt"
      local _padded; _padded=$(printf '%-*s' "$ROW_TITLE_W" "$ROW_TITLE")
      PICKER_ENTRIES+=("${ROW_LEFT}$(ui_paint fd_title "$_padded")${ROW_RIGHT}")
      PICKER_SLUGS+=("$slug")
      PICKER_TYPES+=("row")
      PICKER_FILTERABLE+=("1")
      PICKER_BUCKET+=("$bb")
      PICKER_TITLE+=("$ROW_TITLE")
      PICKER_TITLE_W+=("$ROW_TITLE_W")
      PICKER_LEFT+=("$ROW_LEFT")
      PICKER_LEFT_HOVER+=("$ROW_LEFT_HOVER")
      PICKER_RIGHT+=("$ROW_RIGHT")
    done <<< "$page_rows"

    # ── inline pagination: "+M next" at bottom when more pages exist ──
    if (( next_count > 0 )); then
      PICKER_ENTRIES+=("$(_build_more_row "+${next_count} next")")
      PICKER_SLUGS+=("__bv_next__")
      PICKER_TYPES+=("action")
      PICKER_FILTERABLE+=("0")
      _picker_meta_empty
    fi

    # Minimal summary — replaces the verbose
    #   "○ backlog  ·  page X of Y  ·  N total"
    # of pre-0.33.3.  Position is now implied by the in-list pagination
    # entries above, and the bucket badge already sits in the header
    # subtitle, so the only orientation the summary still owes the
    # user is the total count.  Dim so it reads as chrome, not data.
    PICKER_ENTRIES+=("")
    PICKER_SLUGS+=("")
    PICKER_TYPES+=("padding")
    PICKER_FILTERABLE+=("0")
    _picker_meta_empty

    PICKER_ENTRIES+=("   $(ui_dim "${total} changes total")")
    PICKER_SLUGS+=("")
    PICKER_TYPES+=("summary")
    PICKER_FILTERABLE+=("0")
    _picker_meta_empty

    PICKER_ENTRIES+=("")
    PICKER_SLUGS+=("")
    PICKER_TYPES+=("padding")
    PICKER_FILTERABLE+=("0")
    _picker_meta_empty

    # Back action.  Pagination is now in-list, so the only chrome
    # action left at the bottom is the back navigation.
    PICKER_ENTRIES+=("$(ui_paint fd_chrome "←  Back to all changes")")
    PICKER_SLUGS+=("__bv_back__")
    PICKER_TYPES+=("action")
    PICKER_FILTERABLE+=("0")
    _picker_meta_empty

    # Two-line branded header — IDENTICAL to the main view.  The user
    # explicitly wants the bucket view's header to match main 1:1
    # (same subtitle tagline, same project line).  Bucket context is
    # already conveyed by:
    #   1. how the user got here (drilling in via "+N more...")
    #   2. the uniform bucket icon/colour at the left of every row
    # so the header doesn't owe them a bucket badge.
    local _project _hdr_line2
    _project=$(basename "$PWD")
    _hdr_line2="$(ui_dim 'project:')  $(ui_paint_bold fd_project "[${_project}]")"
    PICKER_HEADER="$(build_picker_header "$(ui_dim 'Code change registry — propose, track, implement, ship')" "$_hdr_line2")"
    if ui_picker "⌕  Search "; then
      case "$PICKER_RESULT_SLUG" in
        __bv_prev__) page=$((page - 1)) ;;
        __bv_next__) page=$((page + 1)) ;;
        __bv_back__) return ;;
        '') ;;
        *) ui_drill "$PICKER_RESULT_SLUG" ;;
      esac
    else
      return
    fi
  done
}

# Sentinel labels (plain — used in case patterns AFTER _norm_picker_line
# strips ANSI). Display values are produced via ui_paint fd_chrome when
# building picker entries.
ACT_ADD='+  Add new change'
ACT_SYNC='⛖  Sync'    # U+26D6 BLACK TWO-WAY LEFT WAY TRAFFIC — plain Unicode (no Nerd Font); full rebuild of per-bucket .index.yaml files
ACT_RELOAD='⟳  Reload'
ACT_EXIT='⏻  Exit'

# Build the brand header shown above the search prompt.  Two lines:
#
#     ★  Foundry  ·  <subtitle>
#        project: <name>
#
# Line 1:
#   ★            — brand mark, bold, in fd_brand (#443199 royal purple)
#   Foundry      — app name, bold, same fd_brand colour
#   ·            — dim separator
#   <subtitle>   — caller-supplied per-screen description, already painted
#
# Line 2 (caller-supplied, already painted) — typically
# "project: <name>".  No tree-branch glyph: the user explicitly asked
# for that to come off.
#
# Returns a string with embedded "\n" between the two lines.  ui_picker
# counts the newlines to figure out where to put the caret.
build_picker_header() {
  local subtitle="${1:-}"   # already-painted text supplied by the caller
  local line2="${2:-}"      # already-painted text supplied by the caller
  local out
  # ★ and "Foundry" rendered bold via ui_paint_bold.  As of 0.32.23 the
  # bold SGR is emitted in its own CSI (see ui.sh) — Terminal.app was
  # silently dropping the bold attribute when bundled with the
  # extended-foreground SGR in a single CSI in 0.32.22.  Colour comes
  # from fd_brand → 256 palette code 27 (#005fff, electric blue with
  # faint green lift) — picked from a 15-row preview after both
  # palette 57 and truecolor #5800FF mis-rendered in the user's
  # Terminal.app profile.
  out="$(ui_paint_bold fd_brand '★')  "
  out+="$(ui_paint_bold fd_brand 'Foundry')"
  if [[ -n "$subtitle" ]]; then
    out+="  $(ui_dim '·')  ${subtitle}"
  fi
  if [[ -n "$line2" ]]; then
    # 18-space indent so line 2 starts at column 19 — flush under the
    # first character of the subtitle (currently "Code change…"), not
    # under the 'F' of Foundry.  Layout reference: cols 1-3 frame
    # indent, col 4 ★, cols 5-6 spaces, cols 7-13 "Foundry", cols
    # 14-15 spaces, col 16 "·", cols 17-18 spaces, col 19 first char
    # of subtitle.
    out+=$'\n                  '"$line2"
  fi
  printf '%s' "$out"
}

# Helper: column widths used by both build_full_row and the picker
# header / "+N more" rows so everything aligns.
_picker_widths() {
  local cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 100)}
  (( cols > 140 )) && cols=140
  local bucket_w=12 created_w=18 updated_w=11
  local title_w=$(( cols - bucket_w - created_w - updated_w - 10 ))
  (( title_w < 20 )) && title_w=20
  printf '%d %d %d %d' "$bucket_w" "$title_w" "$created_w" "$updated_w"
}

# Build the column-header line for the custom picker. The picker prefixes
# each rendered row with "▸ " (cursor) or "  " (non-cursor) — 2 cells.
# Row content is then icon(1) + sep(2) + bucket, so bucket text starts at
# column 5. The column-header line has no icon, so 3 leading spaces here +
# 2 cells from the picker = 5 → STATUS aligns with "backlog".
# Small-caps via ui_pad_visual which counts visual cells (wc -m).
_build_header_row() {
  read -r bw tw cw uw <<< "$(_picker_widths)"
  printf '   %s  %s  %s  %s' \
    "$(ui_dim "$(ui_pad_visual "$(ui_small_caps STATUS)" "$bw")")" \
    "$(ui_dim "$(ui_pad_visual "$(ui_small_caps TITLE)" "$tw")")" \
    "$(ui_dim "$(ui_pad_visual "$(ui_small_caps CREATED)" "$cw")")" \
    "$(ui_dim "$(ui_pad_visual "$(ui_small_caps UPDATED)" "$uw")")"
}

# Build a chrome row in the "+N more..." visual style — blank bucket
# cell, caller-supplied label painted in fd_more across the title
# cell, blank date cells.  Column widths come from _picker_widths so
# alignment with real change rows is preserved.
#
# Used for:
#   - main-screen bucket overflow ("+5 more...")
#   - bucket-view pagination       ("+N previous" / "+M next")
#
# fd_more is 256-palette 110 (#87afd7) — same baby-blue family as
# fd_title (153, #afd7ff) dropped roughly 15% in luminance, so these
# rows sit "under" real titles without falling into chrome-gray.
_build_more_row() {
  local label="$1"
  read -r bw tw cw uw <<< "$(_picker_widths)"
  printf '   %s  %s  %s  %s' \
    "$(printf '%-*s' "$bw" "")" \
    "$(ui_paint fd_more "$(printf '%-*s' "$tw" "$label")")" \
    "$(printf '%-*s' "$cw" "")" \
    "$(printf '%-*s' "$uw" "")"
}

# Build inline stats string — used both as a header second-line and as
# the (now-removed) bottom summary in earlier versions.  Output shape:
#   "N changes  ·  ○ a  ⊙ b  ● c  ⊗ d"
# Colors:
#   "N changes"       → ui_dim
#   "·" separator     → ui_dim
#   "<icon> <count>"  → per-bucket color (one painted segment so the ANSI
#                       reset doesn't bleed back to dim)
_build_stats_inline() {
  local total="$1" all_rows="$2"
  local s
  s="$(ui_dim "$total changes")"
  local b
  for b in "${BUCKETS[@]}"; do
    local cnt; cnt=$(printf '%s\n' "$all_rows" | awk -F'\t' -v b="$b" '$1 == b' | wc -l | tr -d ' ')
    s+="  $(ui_dim '·')  $(ui_paint "$(ui_bucket_color "$b")" "$(ui_icon "$b") $cnt")"
  done
  printf '%s' "$s"
}

# Bottom summary row — picker-formatted (leading indent matches the
# column-header / +N-more / row prefix so everything aligns).  Wraps
# _build_stats_inline.
_build_summary_row() {
  printf '   %s' "$(_build_stats_inline "$1" "$2")"
}

# ── ui_picker — custom interactive picker ─────────────────────────────────
#
# Why custom: gum filter and fzf both visit every row with the cursor — no
# way to skip non-selectables (column headers, summary, padding) in the
# middle of the list. This picker reads parallel arrays the caller fills:
#
#   PICKER_ENTRIES[i]    — display line (may contain ANSI escapes)
#   PICKER_SLUGS[i]      — return key for selectables; "" otherwise
#   PICKER_TYPES[i]      — 'row' | 'action' | 'header' | 'padding' | 'summary'
#   PICKER_FILTERABLE[i] — '1' to include row in text-filter; '0' to always show
#
# Optional per-row (set only for type='row'; default to '' for the rest):
#   PICKER_BUCKET[i]   — bucket name; powers Tab → jump to next bucket
#   PICKER_TITLE[i]    — raw title text (truncated, unpadded, no ANSI)
#   PICKER_TITLE_W[i]  — target visual width for padding the title cell
#   PICKER_LEFT[i]     — pre-painted "<icon>  <bucket>  " segment
#   PICKER_RIGHT[i]    — pre-painted "  <created>  <updated>" segment
# When a filter is active and the row's title contains the filter substring
# (case-insensitive), the picker rebuilds the row from LEFT + highlighted
# title + RIGHT so the match appears in fd_match (pale gold) while the rest
# of the title stays in fd_title.
#
# Cursor only lands on type='row' or 'action'. Type-to-filter is always on:
# typed chars build a substring filter against filterable entries (rows).
# Non-filterable entries (headers/summary/padding/actions) always show.
#
# Keys:
#   ↑ / ↓     move cursor through selectables
#   Tab       on 'row'    → jump to first selectable of the NEXT bucket
#             on 'action' → behave like ↓
#   ↵         select (sets PICKER_RESULT_SLUG and returns 0)
#   ⌫         delete one char from filter
#   ⎋         cancel (returns 1)
#
# Sets globals on selection:
#   PICKER_RESULT_SLUG, PICKER_RESULT_ENTRY
# Return: 0 = ↵ selected, 1 = esc.
ui_picker() {
  local prompt_label="${1:-⌕ Search }"

  local filter="" filter_lc="" cursor=0
  # First-render flag — used once below to snap the initial cursor
  # onto the first 'row' selectable instead of the first 'action'.
  # Matters for the bucket view's "+N previous" pagination entry
  # which sits ABOVE the data rows when page > 1; without this nudge
  # the cursor would land on the prev-page button and Enter would
  # accidentally page backwards.
  local _first_render=1
  # Filter-changed flag — set when the user types into or backspaces
  # the search box.  Triggers the same "jump cursor to first 'row'
  # selectable" logic as _first_render, so typing in search snaps the
  # cursor onto the first matching content row (proposal line /
  # history entry in the detail view).  Cleared after the rebuild.
  local _filter_changed=0
  local stty_save; stty_save=$(stty -g)
  stty -echo -icanon
  # Hide the hardware cursor — we draw our own ▏ thin bar so we control
  # its color (fd_search neon purple) and blink rate.  Terminals can't
  # repaint their native caret with a custom colour, so faking it is
  # the only way.
  printf '\033[?25l'

  PICKER_RESULT_SLUG=""
  PICKER_RESULT_ENTRY=""
  local rc=0
  local n_total=${#PICKER_ENTRIES[@]}

  # ── per-picker caches built ONCE ─────────────────────────────────────────
  # Pre-derive everything that doesn't depend on the filter or cursor so
  # the per-frame loop stays in pure bash — no sed/tr forks during render.
  #   entries_lc[i]     — ANSI-stripped lowercase for substring filtering
  #   entries_brand[i]  — entry recoloured in fd_brand (used when the
  #                       cursor lands on an action item)
  #   title_lc[i]       — lowercase raw title for filter-match highlighting
  local -a entries_lc=() entries_brand=() title_lc=()
  local i stripped
  for (( i = 0; i < n_total; i++ )); do
    stripped=""
    if [[ "${PICKER_FILTERABLE[$i]}" == "1" || "${PICKER_TYPES[$i]}" == "action" ]]; then
      stripped=$(printf '%s' "${PICKER_ENTRIES[$i]}" | ui_strip_ansi)
    fi
    if [[ "${PICKER_FILTERABLE[$i]}" == "1" ]]; then
      entries_lc[$i]=$(printf '%s' "$stripped" | tr '[:upper:]' '[:lower:]')
    else
      entries_lc[$i]=""
    fi
    if [[ "${PICKER_TYPES[$i]}" == "action" ]]; then
      entries_brand[$i]=$(ui_paint fd_brand "$stripped")
    else
      entries_brand[$i]=""
    fi
    if [[ "${PICKER_TYPES[$i]}" == "row" && -n "${PICKER_TITLE[$i]:-}" ]]; then
      title_lc[$i]=$(printf '%s' "${PICKER_TITLE[$i]}" | tr '[:upper:]' '[:lower:]')
    else
      title_lc[$i]=""
    fi
  done

  # Brand-colour SGR for cursor hover (row-title + action-label and
  # the row's status icon via PICKER_LEFT_HOVER).  Pre-derived once
  # per render-init so the per-row title printf below stays a single
  # SGR.  CRITICAL: built via `printf -v` (not single-quote literal)
  # so the `\033` in the format string is interpreted as the real
  # ESC byte — otherwise printf %s in the title format below would
  # emit it as 4 literal characters (`\`, `0`, `3`, `3`), which the
  # user reported in 0.33.2 as "\033[38;5;27mSome change 4" showing
  # up verbatim in the title cell.
  local _brand_code _brand_fmt _title_dim_fmt
  _brand_code=$(ui_color_code fd_brand)
  if [[ "$_brand_code" == \#* ]]; then
    printf -v _brand_fmt '\033[%sm' "$(_ui_fg_seq "$_brand_code")"
  else
    printf -v _brand_fmt '\033[38;5;%sm' "$_brand_code"
  fi
  printf -v _title_dim_fmt '\033[38;5;153m'

  # Static render fragments.  ⌕ + "Search" share the brand colour
  # (fd_search → 256 code 27, electric blue #005fff); the caret a few
  # columns to the right is painted in the matching fd_caret slot.
  local prompt_painted; prompt_painted=$(ui_paint fd_search "$prompt_label")

  # Caret SGR fragment — pre-derived once so both the static frame and
  # the background animator emit identical bytes for the ▏ glyph.  Used
  # to be hard-coded `\033[38;5;99m` (256-palette violet); now resolves
  # through fd_caret so the palette change in ui.sh propagates here
  # without two edits.
  local _caret_code; _caret_code=$(ui_color_code fd_caret)
  local _caret_seq; _caret_seq=$(_ui_fg_seq "$_caret_code")
  # Selector arrow on the cursor row.  ➤ (U+27A4 BLACK RIGHTWARDS
  # ARROWHEAD) — solid filled, heavier than the previous ▸ small
  # triangle so the user can see "this is the selected row" at a
  # glance.  Painted in fd_brand so the selector reads as part of the
  # Foundry brand identity (matches ★ + "Foundry" + ⌕ + caret).
  local cursor_arrow;   cursor_arrow=$(ui_paint fd_brand '➤')

  # Optional N-line header above the search prompt.  Callers set
  # PICKER_HEADER (a fully-painted, ANSI-styled string with embedded
  # "\n" between lines) to brand the screen.  When set, the prompt row
  # shifts down by (1 + n_lines): header occupies rows 2..(1+n_lines),
  # then a blank, then the prompt on (3 + n_lines).
  #   no header  → caret_row = 2
  #   1-line     → caret_row = 4
  #   2-line     → caret_row = 5
  # Header line count is derived from \n count in PICKER_HEADER.
  local picker_header="${PICKER_HEADER:-}"
  local caret_row=2
  if [[ -n "$picker_header" ]]; then
    local _nl_only="${picker_header//[^$'\n']}"
    local _n_header_lines=$((${#_nl_only} + 1))
    caret_row=$((3 + _n_header_lines))
  fi

  # ── caret blink sidecar ─────────────────────────────────────────────────
  # A background process drives the caret animation while the main loop
  # blocks on read().  The animator alternates on/off at row $caret_row
  # — a thin ▏ in fd_search for 1 s, then a blank space for 1 s, ≈ 0.5 Hz
  # blink.  Decouples cursor animation from input — read() can block
  # forever on the main loop and the caret keeps blinking.
  #
  # Coordination: before drawing a full frame the main loop SIGSTOPs the
  # animator so its writes can't interleave with the frame's bytes, then
  # SIGCONTs after the frame and the new cursor column have been written.
  # Cleanup on exit: rm the col file (animator loop sees missing file and
  # exits), then SIGTERM, then wait.
  local anim_col_file; anim_col_file=$(mktemp -t fdcaret 2>/dev/null || mktemp)
  printf '%d' 14 > "$anim_col_file"

  # Capture caret_row in a child-safe variable.  The subshell forks
  # with `set +eu` so an unbound `caret_row` shouldn't abort, but
  # explicit shadow keeps the printf format from receiving an empty
  # string if anything weird happens with scope across the `&`.
  local _ar="$caret_row"
  local _cs="$_caret_seq"
  (
    # The subshell inherits set -euo pipefail from the parent; disable so
    # transient failures (kill races on parent shutdown, tmp-file read
    # blips) can't tear down the animator prematurely.
    set +euo pipefail
    trap 'exit 0' TERM INT
    _row="${_ar:-2}"
    _seq="${_cs:-38;5;99}"
    phase=0
    while [[ -f "$anim_col_file" ]]; do
      col=$(<"$anim_col_file" 2>/dev/null) || break
      # If the read landed mid-update (file truncated to 0 bytes before
      # the new column was written) OR yielded a non-integer, skip this
      # tick rather than painting at a stale fallback column.  The old
      # `[[ -z "$col" ]] && col=14` line was the cause of "caret stuck
      # at column 14 covering the first typed char" — when the race
      # fired the caret got nailed to position 14 regardless of filter
      # length.
      if [[ -z "$col" || ! "$col" =~ ^[0-9]+$ ]]; then
        sleep 1
        continue
      fi
      # Slow 2-phase blink — 1 s bright, 1 s blank = 2 s total = 0.5 Hz.
      # Each printf goes directly to /dev/tty per call (bypasses libc's
      # line-buffered subshell stdout, which was stranding bytes between
      # sleeps).  Colour comes from fd_caret (currently 256 code 210
      # 256 code 27 electric blue #005fff) — matches the brand strip so the caret
      # reads as "Foundry's" cursor rather than a generic system one.
      case "$phase" in
        0) printf '\033[%s;%sH\033[%sm▏\033[0m' "$_row" "$col" "$_seq" >/dev/tty ;;
        1) printf '\033[%s;%sH \033[0m'         "$_row" "$col"         >/dev/tty ;;
      esac
      phase=$(( (phase + 1) % 2 ))
      sleep 1
    done
  ) </dev/null >/dev/null 2>/dev/null &
  local anim_pid=$!

  # Prompt cell layout (0.32.23 — extra gap before the caret):
  #   col 1-3 : leading indent (3 spaces)
  #   col 4   : ⌕            (search icon)
  #   col 5-6 : 2 gap spaces
  #   col 7-12: "Search"    (anchor — aligns with STATUS / foundry)
  #   col 13  : trailing space   ← from prompt_label "⌕ Search "
  #   col 14  : breathing space  ← new in 0.32.23 (the explicit ' ' below)
  #   col 15  : caret  (when filter is empty)
  # When the user types, the caret slides right by ${#filter} chars,
  # always with one breathing space between the typed text and ▏ — no
  # more "Search [foo]▏" gluing.  PROMPT_COLS = 14 so that
  #   caret_col = PROMPT_COLS + 1 + ${#filter} = 15 (empty),
  # which matches the static frame's column index.
  local PROMPT_COLS=14

  local needs_full_redraw=1
  local n_sel=0 current=-1
  local -a vis_idx=() sel_idx=()

  while true; do
    if (( needs_full_redraw )); then
      # Freeze the animator so its mid-tick write can't tear the frame.
      # `|| true` because under set -e a missing pid would abort the loop;
      # if the animator already died, we just keep going without a pulse.
      kill -STOP "$anim_pid" 2>/dev/null || true

      # ── filter pass ─────────────────────────────────────────────────────
      vis_idx=(); sel_idx=()
      for (( i = 0; i < n_total; i++ )); do
        if [[ "${PICKER_FILTERABLE[$i]}" == "1" && -n "$filter_lc" ]]; then
          [[ "${entries_lc[$i]}" != *"$filter_lc"* ]] && continue
        fi
        vis_idx+=("$i")
        if [[ "${PICKER_TYPES[$i]}" == "row" || "${PICKER_TYPES[$i]}" == "action" ]]; then
          sel_idx+=("$((${#vis_idx[@]} - 1))")
        fi
      done

      n_sel=${#sel_idx[@]}
      if (( n_sel == 0 )); then
        cursor=0
      else
        if (( _first_render )) || (( _filter_changed )); then
          # Two conditions, same jump:
          #   _first_render   — initial cursor placement: skip action
          #                     items, land on first data row.
          #   _filter_changed — user typed into / backspaced the search
          #                     prompt; jump to the first content row
          #                     that survived the filter so the user
          #                     immediately sees the match they're
          #                     looking for highlighted.
          # Falls through to cursor=0 if no row-type selectables exist
          # in the filtered set (e.g. all proposal lines hidden by an
          # unmatched query — cursor lands on the first action, which
          # for the detail view is "← Back").
          local _k _vi _ei
          for (( _k = 0; _k < n_sel; _k++ )); do
            _vi="${sel_idx[$_k]}"
            _ei="${vis_idx[$_vi]}"
            if [[ "${PICKER_TYPES[$_ei]}" == "row" ]]; then
              cursor=$_k
              break
            fi
          done
        fi
        (( cursor >= n_sel )) && cursor=$((n_sel - 1))
        (( cursor < 0 )) && cursor=0
      fi
      _first_render=0
      _filter_changed=0
      current=-1
      (( n_sel > 0 )) && current="${sel_idx[$cursor]}"

      # ── render one frame in one printf ──────────────────────────────────
      # \033[H\033[2J replaces the external `clear`.  3 leading spaces
      # (was 4 pre-0.32.9) so ⬢ on the brand strip and ⌕ on the prompt
      # both anchor at col 4, while "foundry" / "Search" / "STATUS" all
      # share col 7.  A bright caret is painted once here; the sidecar
      # animator overwrites it on its next tick to continue the pulse.
      # When PICKER_HEADER is set, the header sits on rows 2..2+n with
      # a blank buffer row, pushing the prompt down by (1 + n_lines).
      local frame=$'\033[H\033[2J\n'
      if [[ -n "$picker_header" ]]; then
        frame+=$'   '"${picker_header}"$'\n\n'
      fi
      # NB: explicit ' ' before the caret SGR.  Without it the caret ▏
      # glues onto either the trailing space of "Search " (when filter
      # is empty) or the last typed character (when not).  The extra
      # space lives outside `ui_bright "$filter"` so the caret column
      # math (PROMPT_COLS = 14) stays in step.
      frame+=$'   '"${prompt_painted}$(ui_bright "$filter") "$'\033['"${_caret_seq}m"$'▏\033[0m\n\n\n'
      local j idx row_render is_cursor
      for (( j = 0; j < ${#vis_idx[@]}; j++ )); do
        idx="${vis_idx[$j]}"
        is_cursor=0
        (( j == current )) && is_cursor=1
        # Title colour on rows:
        #   default (no cursor, no filter match) → ${PICKER_ENTRIES[i]} verbatim
        #   filter match, no cursor              → 153 fd_title + 222 fd_match
        #   cursor on row                        → _brand_fmt (fd_brand) for
        #                                          the title AND the status
        #                                          icon (via PICKER_LEFT_HOVER)
        # action items get the entire label re-painted in fd_brand via
        # entries_brand[idx] so the action label matches the brand-coloured
        # selector arrow on its left.
        if [[ "${PICKER_TYPES[$idx]}" == "row" ]]; then
          local _has_match=0 _use_left
          # `:-` defaults guard against any builder path that pushes
          # to PICKER_ENTRIES but skips the parallel hover array (e.g.
          # build_detail_entries via the _picker_push_* helpers).
          # Without the default, set -u would abort on an unbound
          # array element when the cursor lands on such a row.
          _use_left="${PICKER_LEFT[$idx]:-}"
          (( is_cursor )) && _use_left="${PICKER_LEFT_HOVER[$idx]:-$_use_left}"
          if [[ -n "$filter_lc" && -n "${title_lc[$idx]}" \
                && "${title_lc[$idx]}" == *"$filter_lc"* ]]; then
            _has_match=1
          fi
          if (( _has_match || is_cursor )); then
            local _t _tw _title_fmt
            _t="${PICKER_TITLE[$idx]}"
            _tw="${PICKER_TITLE_W[$idx]}"
            if (( is_cursor )); then
              _title_fmt="$_brand_fmt"
            else
              _title_fmt="$_title_dim_fmt"
            fi
            # NB: split assignments — bash 3.2 evaluates `local a=… b=$((…a…))`
            # right-to-left through the outer scope, which trips set -u when
            # `a` doesn't exist there yet.
            local _vlen _pad _padding
            _vlen=${#_t}
            _pad=$((_tw - _vlen))
            (( _pad < 0 )) && _pad=0
            printf -v _padding '%*s' "$_pad" ''
            if (( _has_match )); then
              local _lc _before_lc _pos _mlen _pre _mat _suf _hl
              _lc="${title_lc[$idx]}"
              _before_lc="${_lc%%"$filter_lc"*}"
              _pos=${#_before_lc}
              _mlen=${#filter_lc}
              _pre="${_t:0:_pos}"
              _mat="${_t:_pos:_mlen}"
              _suf="${_t:_pos+_mlen}"
              # title-fmt prefix → 222 fd_match → title-fmt suffix → pad, reset
              printf -v _hl '%s%s\033[38;5;222m%s%s%s%s\033[0m' \
                "$_title_fmt" "$_pre" "$_mat" "$_title_fmt" "$_suf" "$_padding"
              row_render="${_use_left}${_hl}${PICKER_RIGHT[$idx]}"
            else
              # Cursor on row, no filter match — recolour title via title-fmt.
              local _ti
              printf -v _ti '%s%s%s\033[0m' "$_title_fmt" "$_t" "$_padding"
              row_render="${_use_left}${_ti}${PICKER_RIGHT[$idx]}"
            fi
          else
            row_render="${PICKER_ENTRIES[$idx]}"
          fi
        else
          row_render="${PICKER_ENTRIES[$idx]}"
        fi
        if (( is_cursor )); then
          if [[ "${PICKER_TYPES[$idx]}" == "action" ]]; then
            # :- default for action entries that didn't get a
            # pre-derived entries_brand[] slot (any builder path that
            # bypassed the standard init loop).  Falls back to the
            # already-coloured PICKER_ENTRIES.
            frame+=" ${cursor_arrow} ${entries_brand[$idx]:-${PICKER_ENTRIES[$idx]}}"$'\n'
          else
            frame+=" ${cursor_arrow} ${row_render}"$'\n'
          fi
        else
          frame+="   ${row_render}"$'\n'
        fi
      done
      printf '%s' "$frame"

      # Tell the animator the new caret column, then resume the pulse.
      # Atomic write via tmp + mv — a bare `> "$anim_col_file"` truncates
      # the file to 0 bytes BEFORE the new content is written, opening a
      # tiny race window where the animator's read sees an empty string.
      # The previous fallback to col=14 hid the race as "caret stuck at
      # column 14".  mv is atomic on the same filesystem so the animator
      # only ever sees a fully-written old or fully-written new value.
      local cur_col=$((PROMPT_COLS + 1 + ${#filter}))
      printf '%d' "$cur_col" > "${anim_col_file}.tmp"
      mv -f "${anim_col_file}.tmp" "$anim_col_file"
      kill -CONT "$anim_pid" 2>/dev/null || true

      needs_full_redraw=0
    fi

    # Block on read — sidecar handles caret pulse in background.  The
    # `|| true` masks read's non-zero return on EOF / signal interrupt so
    # set -e doesn't unwind the picker; an empty key is then treated as
    # Enter, which is what would normally happen anyway.
    local key=""
    IFS= read -rsn1 key || true

    if [[ -z "$key" ]]; then
      # `read -n1` returns rc=0 with empty $key when the line terminator
      # (Enter) arrives — the delimiter is consumed but not stored.
      if (( n_sel > 0 )); then
        local orig_idx="${vis_idx[$current]}"
        PICKER_RESULT_SLUG="${PICKER_SLUGS[$orig_idx]}"
        PICKER_RESULT_ENTRY="${PICKER_ENTRIES[$orig_idx]}"
      fi
      break
    fi

    case "$key" in
      $'\e')
        # Arrow key (ESC [ A/B) or bare ESC.  Bash 3.2 has no fractional
        # `read -t`; stty min/time peeks the rest of the sequence.
        stty -icanon min 0 time 1
        local seq="" dir=""
        IFS= read -rsn1 seq
        if [[ "$seq" == '[' ]]; then
          IFS= read -rsn1 dir
        fi
        stty -icanon min 1 time 0
        if [[ "$seq" == '[' ]]; then
          case "$dir" in
            A) (( n_sel > 0 )) && cursor=$(( (cursor - 1 + n_sel) % n_sel )) ;;
            B) (( n_sel > 0 )) && cursor=$(( (cursor + 1) % n_sel )) ;;
          esac
        else
          rc=1; break
        fi ;;
      $'\t')
        # Tab: on a row jump to first selectable in the next bucket; on
        # an action item (or anywhere with no bucket) behave like ↓.
        if (( n_sel > 0 )); then
          local _cv="${sel_idx[$cursor]}" _co
          _co="${vis_idx[$_cv]}"
          local _ctype="${PICKER_TYPES[$_co]}" _cbuck="${PICKER_BUCKET[$_co]:-}"
          if [[ "$_ctype" == "action" || -z "$_cbuck" ]]; then
            cursor=$(( (cursor + 1) % n_sel ))
          else
            local _target="$cursor" _k _kv _ko _kb
            for (( _k = 1; _k <= n_sel; _k++ )); do
              local _cand=$(( (cursor + _k) % n_sel ))
              _kv="${sel_idx[$_cand]}"
              _ko="${vis_idx[$_kv]}"
              _kb="${PICKER_BUCKET[$_ko]:-}"
              # First selectable with a different bucket (or no bucket,
              # i.e. an action) — land there.
              if [[ "$_kb" != "$_cbuck" ]]; then
                _target="$_cand"; break
              fi
            done
            cursor="$_target"
          fi
        fi ;;
      $'\x7f'|$'\b')
        filter="${filter%?}"
        filter_lc="${filter_lc%?}"
        cursor=0
        _filter_changed=1 ;;
      [[:print:]])
        filter+="$key"
        # tr fork happens once per keypress (human-paced), not per frame.
        filter_lc+=$(printf '%s' "$key" | tr '[:upper:]' '[:lower:]')
        cursor=0
        _filter_changed=1 ;;
    esac
    needs_full_redraw=1
  done

  # Stop the animator before restoring terminal state.  All three calls
  # tolerate failure — the animator may have died on its own already.
  rm -f "$anim_col_file" 2>/dev/null || true
  kill "$anim_pid" 2>/dev/null || true
  wait "$anim_pid" 2>/dev/null || true

  stty "$stty_save" 2>/dev/null || true
  printf '\033[?25h'  # show hardware cursor again
  return $rc
}

# Build picker entries — populates four parallel globals consumed by
# ui_picker:
#   PICKER_ENTRIES    — display lines (ANSI-styled)
#   PICKER_SLUGS      — return key per selectable; sentinels for actions:
#                         __more__<b>  "+N more" expand bucket
#                         __act_add__  "+ Add new"
#                         __act_reload__ reload
#                         __act_exit__ exit
#   PICKER_TYPES      — 'row'|'action'|'header'|'padding'|'summary'|'info'
#   PICKER_FILTERABLE — '1' for rows (subject to search filter), '0' for rest
#
# Layout: column header → rows (per bucket, capped + "+N more") → blank
# padding → summary → blank padding → action items.
# Append empty placeholders to all per-row metadata arrays.  Keeps them
# parallel with PICKER_ENTRIES so the picker can index any slot safely.
# CRITICAL: every meta array must get a push here, including
# PICKER_LEFT_HOVER (which the cursor-hover render path indexes by
# absolute PICKER_ENTRIES index, not by row count).
_picker_meta_empty() {
  PICKER_BUCKET+=("")
  PICKER_TITLE+=("")
  PICKER_TITLE_W+=("0")
  PICKER_LEFT+=("")
  PICKER_LEFT_HOVER+=("")
  PICKER_RIGHT+=("")
}

# ── detail-screen push helpers (called by build_detail_entries) ──────────
# These keep all parallel arrays in lock-step so cursor navigation can
# never index past the end of any meta array.  Push the entry, then call
# _picker_meta_empty for the unused per-row fields.
_picker_push_padding() {
  PICKER_ENTRIES+=("")
  PICKER_SLUGS+=("")
  PICKER_TYPES+=("padding")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty
}

# Info row — display-only, cursor skips over it.  Used in detail-view
# for headings (PROPOSAL, HISTORY) and rendered metadata lines.
_picker_push_info() {
  PICKER_ENTRIES+=("$1")
  PICKER_SLUGS+=("")
  PICKER_TYPES+=("info")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty
}

# Action row — cursor lands on it; selecting returns the slug arg.
_picker_push_action() {
  PICKER_ENTRIES+=("$1")
  PICKER_SLUGS+=("$2")
  PICKER_TYPES+=("action")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty
}

# Selectable content row — proposal/history line the user can filter
# and land cursor on.  $1 carries the rendered (ANSI-styled) bytes the
# picker shows in the neutral case; $2 carries the plain-text title
# the picker substring-slices for filter-match highlight rebuild and
# for type-to-filter matching.  Slug is empty so Enter on a content
# row is a no-op — ui_drill's case dispatcher handles "" as continue
# (don't exit the detail screen, just re-render).
#
# PICKER_LEFT holds a 3-cell leading indent so the match-highlight
# rebuild lands content at the same column as PICKER_ENTRIES rendered
# in the neutral case (the picker adds its own 3-cell prefix in
# front of PICKER_LEFT).  PICKER_TITLE_W = visual cells in the plain
# title (good enough for ASCII; non-ASCII content rounds to byte
# count which over-pads slightly but doesn't break layout).
_picker_push_content() {
  PICKER_ENTRIES+=("$1")
  PICKER_SLUGS+=("")
  PICKER_TYPES+=("row")
  PICKER_FILTERABLE+=("1")
  PICKER_BUCKET+=("")
  PICKER_TITLE+=("$2")
  PICKER_TITLE_W+=("${#2}")
  PICKER_LEFT+=("")
  PICKER_RIGHT+=("")
}

build_main_entries() {
  PICKER_ENTRIES=()
  PICKER_SLUGS=()
  PICKER_TYPES=()
  PICKER_FILTERABLE=()
  PICKER_BUCKET=()
  PICKER_TITLE=()
  PICKER_TITLE_W=()
  PICKER_LEFT=()
  PICKER_LEFT_HOVER=()
  PICKER_RIGHT=()

  local rows; rows=$(collect_rows all)

  # Extra blank row before the column header — user wanted one more
  # line of breathing space between the ⌕ Search caret and the
  # STATUS / TITLE / CREATED / UPDATED strip.
  PICKER_ENTRIES+=("")
  PICKER_SLUGS+=("")
  PICKER_TYPES+=("padding")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty

  # Column headers.
  PICKER_ENTRIES+=("$(_build_header_row)")
  PICKER_SLUGS+=("")
  PICKER_TYPES+=("header")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty

  # Blank padding row beneath the column header — the user wanted the
  # STATUS / TITLE / CREATED / UPDATED strip to breathe before the data
  # rows start.  Type=padding so the cursor skips it.
  PICKER_ENTRIES+=("")
  PICKER_SLUGS+=("")
  PICKER_TYPES+=("padding")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty

  local limit; limit="$(config_get list_per_bucket_limit 3)"
  for b in "${BUCKETS[@]}"; do
    local bucket_rows; bucket_rows=$(printf '%s\n' "$rows" \
      | awk -F'\t' -v b="$b" '$1 == b' \
      | apply_sort "$MAIN_SORT" "$MAIN_REVERSE")
    [[ -z "$bucket_rows" ]] && continue
    local n; n=$(printf '%s\n' "$bucket_rows" | wc -l | tr -d ' ')
    local show="$bucket_rows"
    (( n > limit )) && show=$(printf '%s\n' "$bucket_rows" | head -n "$limit")
    while IFS=$'\t' read -r bb slug title _ upd crt; do
      # Use build_row_parts so we can keep the title-cell data around for
      # filter-match highlighting in the picker.
      build_row_parts "$bb" "$title" "$upd" "$crt"
      local _padded; _padded=$(printf '%-*s' "$ROW_TITLE_W" "$ROW_TITLE")
      PICKER_ENTRIES+=("${ROW_LEFT}$(ui_paint fd_title "$_padded")${ROW_RIGHT}")
      PICKER_SLUGS+=("$slug")
      PICKER_TYPES+=("row")
      PICKER_FILTERABLE+=("1")
      PICKER_BUCKET+=("$bb")
      PICKER_TITLE+=("$ROW_TITLE")
      PICKER_TITLE_W+=("$ROW_TITLE_W")
      PICKER_LEFT+=("$ROW_LEFT")
      PICKER_LEFT_HOVER+=("$ROW_LEFT_HOVER")
      PICKER_RIGHT+=("$ROW_RIGHT")
    done <<< "$show"
    if (( n > limit )); then
      PICKER_ENTRIES+=("$(_build_more_row "+$((n - limit)) more...")")
      PICKER_SLUGS+=("__more__$b")
      PICKER_TYPES+=("action")
      # Filterable=1 so "+N more" hides when the user is searching by text
      # (its label "+N more..." rarely matches a query).
      PICKER_FILTERABLE+=("1")
      # Tag the +N more action with the bucket it belongs to — Tab on the
      # last row of bucket X then lands on the next bucket (not on +N more
      # which still belongs to bucket X).
      PICKER_BUCKET+=("$b")
      PICKER_TITLE+=("")
      PICKER_TITLE_W+=("0")
      PICKER_LEFT+=("")
      PICKER_LEFT_HOVER+=("")
      PICKER_RIGHT+=("")
      # Empty padding row after +N more.  Note: the user has asked
      # multiple times for "half a row" of gap here.  In a cell-based
      # terminal that's physically not possible — rows are atomic units
      # of the grid, so the available choices are 0 rows or 1 row of
      # gap.  0.32.7's ▁-glyph approximation drew a visible line
      # instead of empty space, which the user rejected; restoring a
      # plain empty pad here is the only "non-zero, non-glyph" option.
      PICKER_ENTRIES+=("")
      PICKER_SLUGS+=("")
      PICKER_TYPES+=("padding")
      PICKER_FILTERABLE+=("0")
      _picker_meta_empty
    fi
  done

  # Bottom summary block — restored in 0.32.9.  In 0.33.0 the user
  # asked to lift the summary one line up: drop the pre-summary
  # padding (the bucket-rows loop's trailing "+N more" padding
  # already leaves a natural gap), keep two padding rows after so
  # the summary doesn't crash into Add/Reload/Exit below.
  local _total; _total=$(printf '%s\n' "$rows" | wc -l | tr -d ' ')
  PICKER_ENTRIES+=("$(_build_summary_row "$_total" "$rows")")
  PICKER_SLUGS+=("")
  PICKER_TYPES+=("summary")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty

  PICKER_ENTRIES+=("")
  PICKER_SLUGS+=("")
  PICKER_TYPES+=("padding")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty

  PICKER_ENTRIES+=("")
  PICKER_SLUGS+=("")
  PICKER_TYPES+=("padding")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty

  # Action items at bottom (always selectable, never filtered).
  PICKER_ENTRIES+=("$(ui_paint fd_chrome "$ACT_ADD")")
  PICKER_SLUGS+=("__act_add__")
  PICKER_TYPES+=("action")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty

  PICKER_ENTRIES+=("$(ui_paint fd_chrome "$ACT_SYNC")")
  PICKER_SLUGS+=("__act_sync__")
  PICKER_TYPES+=("action")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty

  PICKER_ENTRIES+=("$(ui_paint fd_chrome "$ACT_RELOAD")")
  PICKER_SLUGS+=("__act_reload__")
  PICKER_TYPES+=("action")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty

  PICKER_ENTRIES+=("$(ui_paint fd_chrome "$ACT_EXIT")")
  PICKER_SLUGS+=("__act_exit__")
  PICKER_TYPES+=("action")
  PICKER_FILTERABLE+=("0")
  _picker_meta_empty
}

# Populate PICKER_* arrays for the change-detail screen.  Layout mirrors
# the main screen's grammar (same indent, same colour roles, same
# header/search) so navigating in/out reads as one continuous surface.
#
#   <padding>
#   <icon>  <bucket>  <change-title-bold>
#   <padding>
#   ꜱᴛᴀᴛᴜꜱ     <status>
#   ᴜᴘᴅᴀᴛᴇᴅ    <relative · full date>
#   ᴄʀᴇᴀᴛᴇᴅ    <full date>
#   [ʀᴇᴀꜱᴏɴ    <decline reason — declined bucket only>]
#   <padding>
#   ᴘʀᴏᴘᴏꜱᴀʟ        ← small caps, no dividers (user spec)
#   <padding>
#     line 1 of proposal.md
#     ... (up to 5 non-blank lines)
#   <padding>
#   ▸  view full   ← action; opens proposal.md in $PAGER
#   <padding>
#   ʜɪꜱᴛᴏʀʏ
#   <padding>
#     <rel>  <actor>  <event>  <details>     (up to 3 most-recent — newest first)
#   +N more...    ← action; opens history.log in $PAGER (only when total > 3)
#   <padding>
#   ▶  Start / ⏸ Pause / ✓ Finish / ↩ Revive / ×  Decline   (bucket-conditional)
#   ←  Back
#
# Inline markdown substitutions applied to body text — strips the
# markers and embeds ANSI for what they mean:
#   **bold**       → SGR 1 (bold) span, markers removed
#   *italic*       → SGR 3 (italic) span, markers removed
#   `code`         → fd_chrome colour, backticks removed
#   [text](url)    → SGR 4 (underline) span on the text, URL dropped
# Order matters: bold (**) before italic (*) so the single-asterisk
# pass doesn't chew the bold markers.  Output bytes already carry
# ANSI — caller MUST NOT pass them through ui_paint or ui_dim again
# at the same scope; instead, use ui_paint's printf form once around
# the full assembled line so the base colour wraps the inline spans.
_render_md_inline() {
  local text="$1"
  # **bold**
  text=$(printf '%s' "$text" | sed -E $'s/\\*\\*([^*]+)\\*\\*/\\\033[1m\\1\\\033[22m/g')
  # `code`
  text=$(printf '%s' "$text" | sed -E $'s/`([^`]+)`/\\\033[38;5;117m\\1\\\033[39m/g')
  # [text](url)
  text=$(printf '%s' "$text" | sed -E $'s/\\[([^]]+)\\]\\([^)]+\\)/\\\033[4m\\1\\\033[24m/g')
  # *italic*
  text=$(printf '%s' "$text" | sed -E $'s/\\*([^*]+)\\*/\\\033[3m\\1\\\033[23m/g')
  printf '%s' "$text"
}

# Render one source line of markdown to display-ready ANSI.  Unlike
# 0.33.9, this STRIPS the syntax markers so the result reads as a
# rendered document, not raw source:
#   "# H1"     → bold + primary, no leading "#"
#   "## H2"    → bold + fd_title, no leading "##"
#   "### h3"   → fd_title, no leading "###"
#   "#### h4+" → fd_chrome, no leading "####"
#   "- item"   → "• " (dim bullet) + fd_title body, inline md applied
#   "1. item"  → "1. " (dim) + fd_title body, inline md applied
#   "> quote"  → "▎ " (fd_chrome) + dim body, inline md applied
#   "```..."   → recessed separator (no fence text shown)
#   ""         → empty (paragraph break)
#   plain text → dim with inline md applied
# Inline _render_md_inline handles bold/italic/code/link rewriting
# within body text regardless of block type.
_render_md_line() {
  local line="$1"
  case "$line" in
    '# '*)
      printf '%s' "$(ui_paint_bold primary "${line#'# '}")" ;;
    '## '*)
      printf '%s' "$(ui_paint_bold fd_title "${line#'## '}")" ;;
    '### '*)
      printf '%s' "$(ui_paint fd_title "${line#'### '}")" ;;
    '#### '*|'##### '*|'###### '*)
      local _h="$line"
      # Strip the leading #s and the single space after them.
      _h="${_h#'######'}"; _h="${_h#'#####'}"; _h="${_h#'####'}"
      _h="${_h# }"
      printf '%s' "$(ui_paint fd_chrome "$_h")" ;;
    '- '*|'* '*|'+ '*)
      printf '%s\033[38;5;153m%s\033[0m' \
        "$(ui_dim '• ')" \
        "$(_render_md_inline "${line:2}")" ;;
    [0-9].' '*|[0-9][0-9].' '*)
      # ordered list — render the number prefix as-is in dim, body in
      # fd_title with inline md applied.
      local _prefix _rest
      if [[ "$line" =~ ^([0-9]+\.\ )(.*)$ ]]; then
        _prefix="${BASH_REMATCH[1]}"
        _rest="${BASH_REMATCH[2]}"
        printf '%s\033[38;5;153m%s\033[0m' \
          "$(ui_dim "$_prefix")" \
          "$(_render_md_inline "$_rest")"
      else
        printf '\033[38;5;244m%s\033[0m' "$(_render_md_inline "$line")"
      fi ;;
    '> '*)
      printf '%s\033[38;5;244m%s\033[0m' \
        "$(ui_paint fd_chrome '▎ ')" \
        "$(_render_md_inline "${line#'> '}")" ;;
    '```'*)
      # Code fence — hide marker, show a quiet horizontal rule so the
      # block is visually framed.
      printf '%s' "$(ui_dim '────────')" ;;
    '')
      # Preserve blank lines as empty entries — paragraph break.
      printf '' ;;
    *)
      printf '\033[38;5;244m%s\033[0m' "$(_render_md_inline "$line")" ;;
  esac
}

# Plain-text (no ANSI) version of one rendered markdown line.  The
# picker substring-slices on PICKER_TITLE for filter-match highlight
# rebuild; that path cannot tolerate ANSI in the title (slicing is
# byte-indexed, ANSI escapes would chop mid-sequence).  By stripping
# the ANSI from _render_md_line's output we get the *visible* text
# the user actually reads — that's also what they're typing into
# search to match against.
_render_md_line_plain() {
  _render_md_line "$1" | sed -E $'s/\033\\[[0-9;]*[a-zA-Z]//g'
}

# Section headings use ui_small_caps + fd_title — the same small-caps
# treatment as the main screen's column headers, with fd_title (not
# dim) because section headings on a single-record screen organise
# the screen rather than label repeating columns.
build_detail_entries() {
  local slug="$1" b="$2"
  local dir="$CHANGES_DIR/$b/$slug"
  local title;   title=$("$TRACKING_SH" get "$dir" title 2>/dev/null)
  local status;  status=$("$TRACKING_SH" get "$dir" status 2>/dev/null)
  local created; created=$("$TRACKING_SH" get "$dir" created_at 2>/dev/null)
  local updated; updated=$("$TRACKING_SH" get "$dir" updated_at 2>/dev/null)
  local reason;  reason=$("$TRACKING_SH" get "$dir" decline_reason 2>/dev/null || true)

  PICKER_ENTRIES=()
  PICKER_SLUGS=()
  PICKER_TYPES=()
  PICKER_FILTERABLE=()
  PICKER_BUCKET=()
  PICKER_TITLE=()
  PICKER_TITLE_W=()
  PICKER_LEFT=()
  PICKER_LEFT_HOVER=()
  PICKER_RIGHT=()

  # ── ACTION BAR (top) ──
  # Per user: action bar at the top, with the go-back selector as a
  # prominent first action.  Cursor lands on the first row-type
  # selectable (the picker's _first_render logic skips past actions
  # to land on the first PROPOSAL content row), so Back is visually
  # there but doesn't capture Enter on opening.  Icons in
  # target-state colour, labels in fd_chrome to match the main
  # screen's "+ Add new change / ⟳ Reload / ⏻ Exit" strip.
  _picker_push_padding
  _picker_push_action "$(ui_paint fd_chrome '←  Back')" "__act_back__"
  case "$b" in
    backlog)
      _picker_push_action "$(ui_paint fd_inprogress '▶')  $(ui_paint fd_chrome 'Start (move to in-progress)')" "__act_start__"
      _picker_push_action "$(ui_paint fd_declined '×')  $(ui_paint fd_chrome 'Decline')" "__act_decline__"
      ;;
    in-progress)
      _picker_push_action "$(ui_paint fd_done '✓')  $(ui_paint fd_chrome 'Finish (move to done)')" "__act_finish__"
      _picker_push_action "$(ui_paint fd_backlog '⏸')  $(ui_paint fd_chrome 'Pause back to backlog')" "__act_pause__"
      _picker_push_action "$(ui_paint fd_declined '×')  $(ui_paint fd_chrome 'Decline')" "__act_decline__"
      ;;
    done)
      : # terminal state — only Back
      ;;
    declined)
      _picker_push_action "$(ui_paint fd_backlog '↩')  $(ui_paint fd_chrome 'Revive (back to backlog)')" "__act_revive__"
      ;;
  esac

  # ── META (no separate title row; title + slug live in the block) ──
  # Plain-text lowercase labels (no small caps, per user feedback in
  # 0.33.11 — small-cap glyphs read as inconsistent letter sizes).
  # 8-cell label column so "updated" fits without truncation; values
  # painted per role: title bold fd_title, slug fd_chrome (code-like),
  # status carries the bucket icon + bucket-coloured name, dates use
  # fd_updated/fd_created, decline-reason in the bucket colour.
  _picker_push_padding
  _picker_push_info "$(printf '   %s  %s' \
    "$(ui_dim "$(printf '%-8s' 'title')")" \
    "$(ui_paint_bold fd_title "$title")")"
  _picker_push_info "$(printf '   %s  %s' \
    "$(ui_dim "$(printf '%-8s' 'slug')")" \
    "$(ui_paint fd_chrome "$slug")")"
  _picker_push_info "$(printf '   %s  %s  %s' \
    "$(ui_dim "$(printf '%-8s' 'status')")" \
    "$(ui_paint fd_icon "$(ui_icon "$b")")" \
    "$(ui_paint "$(ui_bucket_color "$b")" "$status")")"
  _picker_push_info "$(printf '   %s  %s' \
    "$(ui_dim "$(printf '%-8s' 'updated')")" \
    "$(ui_paint fd_updated "$(ui_date_relative "$updated") · $(ui_date_full "$updated")")")"
  _picker_push_info "$(printf '   %s  %s' \
    "$(ui_dim "$(printf '%-8s' 'created')")" \
    "$(ui_paint fd_created "$(ui_date_full "$created")")")"
  if [[ -n "$reason" ]]; then
    _picker_push_info "$(printf '   %s  %s' \
      "$(ui_dim "$(printf '%-8s' 'reason')")" \
      "$(ui_paint "$(ui_bucket_color "$b")" "$reason")")"
  fi

  # ── PROPOSAL ──
  # Full document rendered inline.  Each source line passes through
  # _render_md_line which strips markdown markers (# / - / ** / `` /
  # [text](url)) and emits ANSI-styled text — the goal is "rendered
  # markdown the user reads", not "syntax-highlighted source".
  # Lines pushed as content rows (type=row, filterable=1) so the
  # ⌕ search prompt filters proposal content and jumps the cursor to
  # the first matching line (picker mod, see ui_picker).  No
  # sub-indent — content sits at the same column (col 7) as the
  # PROPOSAL heading because the user explicitly asked for the right-
  # shift to come off.
  if [[ -f "$dir/proposal.md" ]]; then
    _picker_push_padding
    _picker_push_info "   $(ui_paint fd_title 'PROPOSAL')"
    _picker_push_padding

    local _ln _rendered _plain
    while IFS= read -r _ln || [[ -n "$_ln" ]]; do
      _rendered="$(_render_md_line "$_ln")"
      _plain="$(_render_md_line_plain "$_ln")"
      if [[ -z "$_plain" ]]; then
        # Blank line → paragraph break, non-filterable info row.
        _picker_push_info ''
      else
        _picker_push_content "$_rendered" "$_plain"
      fi
    done < "$dir/proposal.md"

    # "View..." action — eye glyph (Nerd Font nf-fa-eye, U+F06E) + the
    # word "View..." in fd_chrome, no leading arrow, no "(N more
    # lines)" hint.  Opens proposal.md in the external pager (glow if
    # available, else cat | less with a friendly prompt).
    _picker_push_padding
    _picker_push_action "$(ui_paint fd_chrome '  View...')" "__view_proposal__"
  fi

  # ── HISTORY ──
  # Same flat-indent rule: column header and data rows align with the
  # HISTORY heading (col 7), no extra sub-indent.  Data rows are
  # content rows (filterable + cursor lands on first match via the
  # picker's filter-jump path).
  if [[ -f "$dir/history.log" ]]; then
    _picker_push_padding
    _picker_push_info "   $(ui_paint fd_title 'HISTORY')"
    _picker_push_padding

    # Column header — plain uppercase (no small caps).  Same padded
    # widths the data rows below use so the columns line up.
    _picker_push_info "$(printf '   %s  %s  %s  %s' \
      "$(ui_dim "$(printf '%-12s' 'WHEN')")" \
      "$(ui_dim "$(printf '%-14s' 'ACTOR')")" \
      "$(ui_dim "$(printf '%-8s'  'EVENT')")" \
      "$(ui_dim 'CHANGE')")"

    local history_lines=()
    local _hln
    while IFS= read -r _hln; do
      history_lines+=("$_hln")
    done < <({ tac "$dir/history.log" 2>/dev/null || tail -r "$dir/history.log"; })

    local hl ts actor event details
    for hl in "${history_lines[@]}"; do
      IFS=$'\t' read -r ts actor event details <<< "$hl"
      local rel; rel=$(ui_date_relative "$ts")
      local actor_color=muted
      [[ "$actor" == "user" ]]          && actor_color=fd_done
      [[ "$actor" == "state-machine" ]] && actor_color=fd_chrome
      local pretty="$details" reason_line=""
      pretty="${pretty//->/ → }"
      if [[ "$pretty" =~ ^(.+)\ \((.+)\)$ ]]; then
        pretty="${BASH_REMATCH[1]}"
        reason_line="${BASH_REMATCH[2]}"
      fi
      local _h_rendered _h_plain
      _h_rendered=$(printf '%s  %s  %s  %s' \
        "$(ui_paint fd_updated "$(printf '%-12s' "$rel")")" \
        "$(ui_paint "$actor_color" "$(printf '%-14s' "$actor")")" \
        "$(ui_paint fd_title    "$(printf '%-8s'  "$event")")" \
        "$(ui_paint fd_created  "$pretty")")
      _h_plain=$(printf '%-12s  %-14s  %-8s  %s' "$rel" "$actor" "$event" "$pretty")
      _picker_push_content "$_h_rendered" "$_h_plain"
      if [[ -n "$reason_line" ]]; then
        # Reason wrap as a non-filterable info row — aligned under the
        # CHANGE column (3 indent + 12 when + 2 + 14 actor + 2 + 8 event + 2 = 43).
        _picker_push_info "$(printf '   %42s%s' '' "$(ui_dim "\"$reason_line\"")")"
      fi
    done
  fi
}

# Interactive REPL — single screen via custom ui_picker:
#   ⌕ Search prompt → column headers → list rows → padding →
#   summary → padding → action items.
# Cursor skips header/padding/summary; only row/action types are selectable.
cmd_interactive() {
  require_foundry
  if [[ "$UI_MODE" != "interactive" ]]; then
    ui_error "no args: pass a subcommand (list/show/new/move/setup) in --plain mode"
    exit 64
  fi

  MAIN_SORT="$(config_get default_sort updated)"
  MAIN_REVERSE=0
  [[ "$(config_get default_reverse false)" == "true" ]] && MAIN_REVERSE=1

  trap 'clear; exit 0' INT

  while true; do
    local rows; rows=$(collect_rows all)

    if [[ -z "$rows" ]]; then
      clear
      ui_header "Foundry" "empty"
      echo
      if gum confirm "Add your first change now?"; then
        ui_add_new
      else
        clear; exit 0
      fi
      continue
    fi

    build_main_entries
    # Two-line branded header.
    #   Line 1: ★ Foundry · <descriptive tagline>
    #   Line 2: project: [<project-name>]
    # The subtitle is a one-line description of what foundry IS as a
    # tool — "Code change registry — propose, track, implement, ship"
    # — names the artifact (registry) and the four lifecycle verbs in
    # the same order the picker columns surface them.  Line 2 anchors
    # the screen to the current project (fd_project — same electric
    # blue-violet as the brand strip — on the bracketed project
    # token, against the dim 'project:' label).
    local _project _hdr_line2
    _project=$(basename "$PWD")
    _hdr_line2="$(ui_dim 'project:')  $(ui_paint_bold fd_project "[${_project}]")"
    PICKER_HEADER="$(build_picker_header "$(ui_dim 'Code change registry — propose, track, implement, ship')" "$_hdr_line2")"
    if ui_picker "⌕  Search "; then
      local slug="$PICKER_RESULT_SLUG"
      case "$slug" in
        __more__*)
          ui_bucket_view "${slug#__more__}" ;;
        __act_add__)
          ui_add_new ;;
        __act_sync__)
          cmd_sync ;;   # full rebuild of per-bucket .index.yaml files
        __act_reload__)
          : ;;   # loop back, rebuild entries
        __act_exit__)
          if gum confirm "Exit foundry?"; then clear; exit 0; fi ;;
        '')
          : ;;   # non-selectable somehow — re-render
        *)
          ui_drill "$slug" ;;
      esac
    else
      # esc — confirm exit
      if gum confirm "Exit foundry?"; then clear; exit 0; fi
    fi
  done
}

# ── dispatch ──────────────────────────────────────────────────────────────
main() {
  if [[ $# -eq 0 ]]; then
    cmd_interactive
    return
  fi
  local sub="$1"; shift
  case "$sub" in
    list)            cmd_list "$@" ;;
    show)            cmd_show "$@" ;;
    new)             cmd_new "$@" ;;
    move)            cmd_move "$@" ;;
    setup)           cmd_setup "$@" ;;
    sync)            cmd_sync "$@" ;;
    -h|--help|help)  usage ;;
    *)               ui_error "unknown subcommand: $sub"; usage ;;
  esac
}

main "$@"
